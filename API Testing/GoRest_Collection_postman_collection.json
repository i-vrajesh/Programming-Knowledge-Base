	"item": [
		{
			"name": "Create User",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"var random = Math.random().toString(36).substring(2);\r",
							"var username = \"john\"+random;\r",
							"var useremail = \"john\"+random+\"@email.com\";\r",
							"\r",
							"pm.environment.set(\"name\",username);\r",
							"pm.environment.set(\"email\",useremail);"
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"    var responseJSON = pm.response.json();\r",
							"    pm.environment.set(\"id\", responseJSON.id);\r",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\r\n    \"name\":\"{{name}}\",\r\n    \"gender\":\"Male\",\r\n    \"email\":\"{{email}}\",\r\n    \"status\":\"Inactive\"\r\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/public/v2/users",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"public",
						"v2",
						"users"
					]
				}
			},
			"response": []
		},
		{
			"name": "Get user details",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"values of json fields\",()=>{\r",
							"    var jsonData = pm.response.json();\r",
							"    pm.expect(jsonData.id).to.eql(pm.environment.get(\"id\"));\r",
							"    pm.expect(jsonData.email).to.eql(pm.environment.get(\"email\"));\r",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
