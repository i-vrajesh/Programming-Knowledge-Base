\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 To find maximum of 3 numbers using simple if 
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int a,b,c,max;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter 3 numbers : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d%d%d",&a,&b,&c);
\par \hich\af0\dbch\af31505\loch\f0   m\hich\af0\dbch\af31505\loch\f0 ax=a;
\par \hich\af0\dbch\af31505\loch\f0   if(max<b)
\par \hich\af0\dbch\af31505\loch\f0    max=b;
\par \hich\af0\dbch\af31505\loch\f0    
\par \hich\af0\dbch\af31505\loch\f0   if(max<c)
\par \hich\af0\dbch\af31505\loch\f0     max=c;
\par \hich\af0\dbch\af31505\loch\f0   printf("Maximum Value   : %d",max);
\par \hich\af0\dbch\af31505\loch\f0   getch();
