\par \hich\af0\dbch\af31505\loch\f0    scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0    printf("\\nNatural numbers from 1 to %d :",n);
\par \hich\af0\dbch\af31505\loch\f0    do
\par \hich\af0\dbch\af31505\loch\f0    \{
