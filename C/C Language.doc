\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   void accept(int[],int);
\par \hich\af0\dbch\af31505\loch\f0   void disp(int[],int);
\par \hich\af0\dbch\af31505\loch\f0   void sort(int[],int);
\par \hich\af0\dbch\af31505\loch\f0   int a[20],n;
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter number of elements : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter elements : ");
\par \hich\af0\dbch\af31505\loch\f0   accept(a,n);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\n\hich\af0\dbch\af31505\loch\f0 Elements Before Sorting :");
\par \hich\af0\dbch\af31505\loch\f0   disp(a,n);
\par \hich\af0\dbch\af31505\loch\f0   sort(a,n);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nElements After Sorting  : ");
\par \hich\af0\dbch\af31505\loch\f0   disp(a,n);
