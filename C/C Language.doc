\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 v\hich\af0\dbch\af31505\loch\f0 oid main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0    int a[20],n,i,j,t;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter number of Elements : ");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0    printf("\\nEnter Elements : \\n");
\par \hich\af0\dbch\af31505\loch\f0    for(i=0;i<n;i++)
\par \hich\af0\dbch\af31505\loch\f0    \{
\par \hich\af0\dbch\af31505\loch\f0       scanf("%d",&a[i]);
\par \hich\af0\dbch\af31505\loch\f0    \}
\par \hich\af0\dbch\af31505\loch\f0    printf("\\n\\nElements Before Sorting : ");
\par \hich\af0\dbch\af31505\loch\f0    for(i=0;i\hich\af0\dbch\af31505\loch\f0 <n;i++)
\par \hich\af0\dbch\af31505\loch\f0    \{
\par \hich\af0\dbch\af31505\loch\f0       printf("\\na[%d]=%d",i,a[i]);
\par \hich\af0\dbch\af31505\loch\f0    \}
\par \hich\af0\dbch\af31505\loch\f0    // sorting //
\par \hich\af0\dbch\af31505\loch\f0    for(i=0;i<n;i++)
\par \hich\af0\dbch\af31505\loch\f0    \{
\par \hich\af0\dbch\af31505\loch\f0      for(j=i+1;j<n;j++)
\par \hich\af0\dbch\af31505\loch\f0      \{
\par \hich\af0\dbch\af31505\loch\f0        if(a[i]>a[j])
\par \hich\af0\dbch\af31505\loch\f0        \{
\par \hich\af0\dbch\af31505\loch\f0              t=a[i];
\par \hich\af0\dbch\af31505\loch\f0              a[i]=a[j];
\par \hich\af0\dbch\af31505\loch\f0              a[j]=t;
\par \hich\af0\dbch\af31505\loch\f0        \}
\par \hich\af0\dbch\af31505\loch\f0      \}
\par \hich\af0\dbch\af31505\loch\f0    \}
\par \hich\af0\dbch\af31505\loch\f0    printf("\\n\\\hich\af0\dbch\af31505\loch\f0 nElements After Sorting : ");
\par \hich\af0\dbch\af31505\loch\f0    for(i=0;i<n;i++)
\par \hich\af0\dbch\af31505\loch\f0    \{
\par \hich\af0\dbch\af31505\loch\f0       printf("\\na[%d]=%d",i,a[i]);
\par \hich\af0\dbch\af31505\loch\f0    \}
\par \hich\af0\dbch\af31505\loch\f0    getch();
\par \}
