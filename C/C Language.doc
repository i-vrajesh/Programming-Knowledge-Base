\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int cno,pmr,lmr,tu,opt,ph;
\par \hich\af0\dbch\af31505\loch\f0   char cname[20];
\par \hich\af0\dbch\af31505\loch\f0   float pt,sc,bamt,tamt;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   prin\hich\af0\dbch\af31505\loch\f0 tf("\\t\\tMENU\\n\\n");
\par \hich\af0\dbch\af31505\loch\f0   printf("---------------------");
\par \hich\af0\dbch\af31505\loch\f0   printf("\\n1-Domestic Prupose\\n");
\par \hich\af0\dbch\af31505\loch\f0   printf("\\n2-Commerical Purpose\\n");
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nEnter your option(1 or 2) : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&opt);
\par \hich\af0\dbch\af31505\loch\f0   if(opt!=1 && opt!=2)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0      printf("\\n\\t\\tInvalid Option");
\par \hich\af0\dbch\af31505\loch\f0      getch();
\par \hich\af0\dbch\af31505\loch\f0      exit(0);
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nEnter Phase Type(1 or 3)");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&ph);
\par \hich\af0\dbch\af31505\loch\f0   if(ph!=1 && ph!=3)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     printf("\\n\\t\\tInvalid Phase");
\par \hich\af0\dbch\af31505\loch\f0     getch();
\par \hich\af0\dbch\af31505\loch\f0     exit(0);
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nEnter Consumer Number       : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&cn\hich\af0\dbch\af31505\loch\f0 o);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nEnter Consumer Name         : ");
\par \hich\af0\dbch\af31505\loch\f0   fflush(stdin);
\par \hich\af0\dbch\af31505\loch\f0   gets(cname);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nEnter Present Month Reading : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&pmr);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nEnter Last Month Reading    : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&lmr);
\par \hich\af0\dbch\af31505\loch\f0   if(lmr>pmr)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     printf("\\n\\t\\\hich\af0\dbch\af31505\loch\f0 tInvalid Reading");
\par \hich\af0\dbch\af31505\loch\f0     getch();
\par \hich\af0\dbch\af31505\loch\f0     exit(0);
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   tu=pmr-lmr;
\par \hich\af0\dbch\af31505\loch\f0   switch(opt)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0      case 1:
\par \hich\af0\dbch\af31505\loch\f0          if(tu<=50)
\par \hich\af0\dbch\af31505\loch\f0              bamt=50*1.45;
\par \hich\af0\dbch\af31505\loch\f0          else if(tu<=100)
\par \hich\af0\dbch\af31505\loch\f0              bamt=(50*1.45)+(tu-50)*2.80;
\par \hich\af0\dbch\af31505\loch\f0          else if(tu<=200)
\par \hich\af0\dbch\af31505\loch\f0              bamt=(5\hich\af0\dbch\af31505\loch\f0 0*1.45)+(50*2.80)+(tu-100)*3.05;
\par \hich\af0\dbch\af31505\loch\f0          else if(tu<=300)
\par \hich\af0\dbch\af31505\loch\f0                bamt=(50*1.45)+(50*2.80)+(100*3.05)+(tu-200)*4.75;
\par \hich\af0\dbch\af31505\loch\f0          else
\par \tab \hich\af0\dbch\af31505\loch\f0   bamt=(50*1.45)+(50*2.80)+(100*3.05)+(100*4.75)+(tu-300)*5.50;
\par \hich\af0\dbch\af31505\loch\f0                pt=0.06*tu;
\par \hich\af0\dbch\af31505\loch\f0          
\par \hich\af0\dbch\af31505\loch\f0     if(ph==1)
\par \hich\af0\dbch\af31505\loch\f0  \hich\af0\dbch\af31505\loch\f0           sc=10.00;
\par \hich\af0\dbch\af31505\loch\f0     else
\par \hich\af0\dbch\af31505\loch\f0           sc=20.00;
\par \hich\af0\dbch\af31505\loch\f0     break;
\par \hich\af0\dbch\af31505\loch\f0   
\par \hich\af0\dbch\af31505\loch\f0     case 2:
\par \hich\af0\dbch\af31505\loch\f0          if(tu<=50)
\par \hich\af0\dbch\af31505\loch\f0              bamt=50*3.95;
\par \hich\af0\dbch\af31505\loch\f0          else
\par \hich\af0\dbch\af31505\loch\f0              bamt=(50*3.95)+(tu-50)*6.20;
\par \hich\af0\dbch\af31505\loch\f0              pt=0.06*tu;
\par \hich\af0\dbch\af31505\loch\f0          if(ph==1)
\par \hich\af0\dbch\af31505\loch\f0              sc=20.00;
\par \hich\af0\dbch\af31505\loch\f0          else
\par \hich\af0\dbch\af31505\loch\f0              sc=50.00;
\par \hich\af0\dbch\af31505\loch\f0         break;
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   tamt=bamt+pt+sc;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("\\t\\t\\t Consumer Details\\n ");
\par \hich\af0\dbch\af31505\loch\f0   printf("-------------------------------------------------\\n");
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nConsumer Number           :  %d",cno);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nC\hich\af0\dbch\af31505\loch\f0 onumer Name              :  %s",cname);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nPresent Month Reading     :  %d",pmr);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nLast Month Reading        :  %d",lmr);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nTotal Units               :  %d",tu);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nPower Tax                 :  %.2f",pt);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\n\hich\af0\dbch\af31505\loch\f0 Service Charge            :  %.2f",sc);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nBill Amount               :  %.2f",bamt);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nTotal Amount              :  %.2f",tamt);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
