\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   FILE *fp;
\par \hich\af0\dbch\af31505\loch\f0   char ch,ch1,st[20];
\par \hich\af0\dbch\af31505\loch\f0   int nc=0,nw=0,nl=0;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter File name : ");
\par \hich\af0\dbch\af31505\loch\f0   gets(st);
\par \hich\af0\dbch\af31505\loch\f0   fp=fopen(st,"rt");
\par \hich\af0\dbch\af31505\loch\f0   \hich\af0\dbch\af31505\loch\f0 if(fp==NULL)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     printf("\\nFile not found");
\par \hich\af0\dbch\af31505\loch\f0     getch();
\par \hich\af0\dbch\af31505\loch\f0     exit(0);
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   ch=getc(fp);
\par \hich\af0\dbch\af31505\loch\f0   while(ch!=EOF)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     if(ch==32 || ch=='\\n')
\par \hich\af0\dbch\af31505\loch\f0     \{
\par \hich\af0\dbch\af31505\loch\f0       nw++;
\par \hich\af0\dbch\af31505\loch\f0       if(ch=='\\n')
\par \hich\af0\dbch\af31505\loch\f0       nl++;
\par \hich\af0\dbch\af31505\loch\f0     \}
\par \hich\af0\dbch\af31505\loch\f0     else
\par \hich\af0\dbch\af31505\loch\f0       nc++;
\par \hich\af0\dbch\af31505\loch\f0       ch1=ch;
\par 
\par 
\par \hich\af0\dbch\af31505\loch\f0     ch=getc(fp);
\par \hich\af0\dbch\af31505\loch\f0     if(ch==32 && ch1==ch)
\par \hich\af0\dbch\af31505\loch\f0       nw--;
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   printf("\\n Number of characters : %d",nc);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\n Number of words      : %d",nw);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\n Number of lines      : %d",nl);
\par \hich\af0\dbch\af31505\loch\f0   fclose(fp);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par 
\par \hich\af0\dbch\af31505\loch\f0 If more than one space is there between 2 words, th\hich\af0\dbch\af31505\loch\f0 e compiler will treats the additional space as a word. To avoid this use the above technique.
\par 
