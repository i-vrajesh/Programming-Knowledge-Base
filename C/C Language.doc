\par }{\rtlch\fcs1 \af44\afs44 \ltrch\fcs0 \f44\fs28\insrsid11017018\charrsid13244520 
\par \hich\af44\dbch\af31505\loch\f44 #include<stdio.h>
\par \hich\af44\dbch\af31505\loch\f44 #include<conio.h>
\par \hich\af44\dbch\af31505\loch\f44 void main()
\par \{
\par \hich\af44\dbch\af31505\loch\f44    char st[40];
\par \hich\af44\dbch\af31505\loch\f44    int i,j,c;
\par \hich\af44\dbch\af31505\loch\f44    clrscr();
\par \hich\af44\dbch\af31505\loch\f44    printf("Enter a String : ");
\par \hich\af44\dbch\af31505\loch\f44    gets(st);
\par \hich\af44\dbch\af31505\loch\f44    _setcursortype(_NOCURSOR);
\par \hich\af44\dbch\af31505\loch\f44    while(1)
\par \hich\af44\dbch\af31505\loch\f44    \{
\par \hich\af44\dbch\af31505\loch\f44      c=(80-strlen(st))/2;
\par \hich\af44\dbch\af31505\loch\f44      clrscr();
\par \hich\af44\dbch\af31505\loch\f44      gotoxy(c,1);
\par \hich\af44\dbch\af31505\loch\f44      printf("%s",st);
\par \hich\af44\dbch\af31505\loch\f44      for\hich\af44\dbch\af31505\loch\f44 (i=0;i<strlen(st);i++)
\par \hich\af44\dbch\af31505\loch\f44      \{
\par \hich\af44\dbch\af31505\loch\f44        if(st[i]!=0)
\par \hich\af44\dbch\af31505\loch\f44        \{
\par \hich\af44\dbch\af31505\loch\f44             for(j=2;j<=25;j++)
\par \hich\af44\dbch\af31505\loch\f44             \{
\par \hich\af44\dbch\af31505\loch\f44                  if(kbhit())
\par \hich\af44\dbch\af31505\loch\f44                  exit(0);
\par \hich\af44\dbch\af31505\loch\f44                  gotoxy(c,j);
\par \hich\af44\dbch\af31505\loch\f44                  printf("%c",st[i]);
\par \hich\af44\dbch\af31505\loch\f44                  gotoxy(c,j-1);
\par \hich\af44\dbch\af31505\loch\f44                  printf("%c",32);
\par \hich\af44\dbch\af31505\loch\f44                 delay(20);
\par \hich\af44\dbch\af31505\loch\f44             \}
\par \hich\af44\dbch\af31505\loch\f44        \}
\par \hich\af44\dbch\af31505\loch\f44        c++;
\par \hich\af44\dbch\af31505\loch\f44      \}
\par \hich\af44\dbch\af31505\loch\f44    \}
\par \}
\par 
