\par \hich\af44\dbch\af31505\loch\f44 #include<conio.h>
\par \hich\af44\dbch\af31505\loch\f44 #define maxval(a,b)   a>b ? a:b
\par \hich\af44\dbch\af31505\loch\f44 void main()
\par \{
\par \hich\af44\dbch\af31505\loch\f44   int a,b,max;
\par \hich\af44\dbch\af31505\loch\f44   clrscr();
\par \hich\af44\dbch\af31505\loch\f44   printf("Enter any two values  : ");
\par \hich\af44\dbch\af31505\loch\f44   scanf("%d%d",&a,&b);
\par \hich\af44\dbch\af31505\loch\f44   max=maxval(a,b);
\par \hich\af44\dbch\af31505\loch\f44   printf("Maximum value = %d",max);
\par \hich\af44\dbch\af31505\loch\f44   getch();
\par \}
\par 
