\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 To enter month and year and to calculate and display number of days in the given month}{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 
\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0  
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int d,m,y;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter month and year (mm-yyyy) : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d%d",&m,&y);
\par \hich\af0\dbch\af31505\loch\f0   if(m==2)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     if((y%4==0 && y%100!=0) || (y%400==0))
\par \hich\af0\dbch\af31505\loch\f0       d=29;
\par \hich\af0\dbch\af31505\loch\f0     else
\par \hich\af0\dbch\af31505\loch\f0       d=28;
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   else if(m==2 || m==4 || m==6 || m==9 || m==11)
\par \hich\af0\dbch\af31505\loch\f0     d=30;
\par \hich\af0\dbch\af31505\loch\f0   else
\par \hich\af0\dbch\af31505\loch\f0     d=31;
\par \hich\af0\dbch\af31505\loch\f0   printf("Nu\hich\af0\dbch\af31505\loch\f0 mber of days : %d",d);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par 
