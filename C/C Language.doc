\par \hich\af0\dbch\af31505\loch\f0 #include<string.h>
\par 
\par \hich\af0\dbch\af31505\loch\f0 struct student
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int sno,c,cpp,java,tot;
\par \hich\af0\dbch\af31505\loch\f0   char sname[20],res[5],gr;
\par \hich\af0\dbch\af31505\loch\f0   float avg;
\par \hich\af0\dbch\af31505\loch\f0  \};
\par 
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   struct student s;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter Student Number :");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&s.sno);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter Student Name  :");
\par \hich\af0\dbch\af31505\loch\f0   fflush(stdin);
\par \hich\af0\dbch\af31505\loch\f0   gets(s.sname);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter Marks in C,C++ and Java  :");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d%d%d",&s.c,&s.cpp,&s.java);
\par \hich\af0\dbch\af31505\loch\f0   s.tot=s.c+s.cpp+s.java;
\par \hich\af0\dbch\af31505\loch\f0   s.avg=(float)s.t\hich\af0\dbch\af31505\loch\f0 ot/3;
\par \hich\af0\dbch\af31505\loch\f0   if(s.c>=50 && s.cpp>=50 && s.java>=50)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     strcpy(s.res,"Pass");
\par \hich\af0\dbch\af31505\loch\f0     if(s.avg>=60)
\par \hich\af0\dbch\af31505\loch\f0       s.gr='A';
\par \hich\af0\dbch\af31505\loch\f0     else
\par \hich\af0\dbch\af31505\loch\f0       s.gr='B';
\par \hich\af0\dbch\af31505\loch\f0    \}
\par \hich\af0\dbch\af31505\loch\f0   else
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0    strcpy(s.res,"Fail");
\par \hich\af0\dbch\af31505\loch\f0    s.gr='-';
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0  clrscr();
\par \hich\af0\dbch\af31505\loch\f0  printf("\\tStudent Result");
\par \hich\af0\dbch\af31505\loch\f0  printf("\\\hich\af0\dbch\af31505\loch\f0 n------------------------------------");
\par \hich\af0\dbch\af31505\loch\f0  printf("\\nStudent Number    :%d",s.sno);
\par \hich\af0\dbch\af31505\loch\f0  printf("\\nStudent Name       :%s",s.sname);
\par \hich\af0\dbch\af31505\loch\f0  printf("\\nMarks in C           :%d",s.c);
\par \hich\af0\dbch\af31505\loch\f0  printf("\\nMarks in C++       :%d",s.cpp);
\par \hich\af0\dbch\af31505\loch\f0  printf("\\nMarks in Java       :%d",s.java\hich\af0\dbch\af31505\loch\f0 );
\par \hich\af0\dbch\af31505\loch\f0  printf("\\nTotal Marks          :%d",s.tot);
\par \hich\af0\dbch\af31505\loch\f0  printf("\\nAverage                :%.2f",s.avg);
\par \hich\af0\dbch\af31505\loch\f0  printf("\\nResult                   :%s",s.res);
\par \hich\af0\dbch\af31505\loch\f0  printf("\\nGrade                    :%c",s.gr);
\par \hich\af0\dbch\af31505\loch\f0  printf("\\n------------------------------------");
\par \hich\af0\dbch\af31505\loch\f0  getch();
\par \}
