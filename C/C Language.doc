\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0    int n,m,rev=0;
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter a number : ");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0    m=n;
\par \hich\af0\dbch\af31505\loch\f0    while(m>0)
\par \hich\af0\dbch\af31505\loch\f0    \{
\par \hich\af0\dbch\af31505\loch\f0       rev=(rev*10)+(m%10);
\par \hich\af0\dbch\af31505\loch\f0       m=m/10;
\par \hich\af0\dbch\af31505\loch\f0    \}
\par \hich\af0\dbch\af31505\loch\f0    if(n==rev)
\par \hich\af0\dbch\af31505\loch\f0      printf("Given number is a Palindrome");
\par \hich\af0\dbch\af31505\loch\f0    else
\par \hich\af0\dbch\af31505\loch\f0      printf("Given number is not Palindrome");
\par \hich\af0\dbch\af31505\loch\f0    getch();
\par \}
