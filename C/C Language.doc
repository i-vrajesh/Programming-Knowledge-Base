\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 LCM of 10 and 15 is 30
\par \hich\af0\dbch\af31505\loch\f0 30%10 = 0 and 30%10 = 0
\par 
\par 
\par \hich\af0\dbch\af31505\loch\f0 2 nd  Method
\par ------------------
\par 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int a,b,lcm;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter any two numbers :");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d%d",&a,&b);
\par \hich\af0\dbch\af31505\loch\f0   if(a>b)
\par \hich\af0\dbch\af31505\loch\f0    lcm=a;
\par \hich\af0\dbch\af31505\loch\f0   else
\par \hich\af0\dbch\af31505\loch\f0    lcm=b;
\par 
\par \hich\af0\dbch\af31505\loch\f0   while( lcm%a!=0 || lcm%b!=0)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     lcm++;
\par \hich\af0\dbch\af31505\loch\f0    \}
\par \hich\af0\dbch\af31505\loch\f0   printf("Lcm of %d and %d is %d",a,b,lcm);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \hich\af0\dbch\af31505\loch\f0  \}
\par 
\par 
\par 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Nested loops :
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 Using a loop statement, within another loop is called as nested loop.
\par 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Program :}{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0   prime_nl}{
\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 .c
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 To display prime numbers from 1 to given number
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0    int n,i,j,count;
\par \hich\af0\dbch\af31505\loch\f0    clrscr();
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter a number : ");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0    printf("Prime Numbers for 1 to %d\\n",n);
\par \hich\af0\dbch\af31505\loch\f0    for(i=1;i<=n;i++)
\par \hich\af0\dbch\af31505\loch\f0    \{
\par \hich\af0\dbch\af31505\loch\f0       count=0;
