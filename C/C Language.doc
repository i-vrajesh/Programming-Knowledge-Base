\par \hich\af0\dbch\af31505\loch\f0     \{
\par \hich\af0\dbch\af31505\loch\f0       if(i==j)
\par \hich\af0\dbch\af31505\loch\f0       \{
\par \hich\af0\dbch\af31505\loch\f0             if(a[i][j]!\hich\af0\dbch\af31505\loch\f0 =1)
