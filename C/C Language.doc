\par }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 To display natural numbers from 1 to n 
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   void disp(int);
\par \hich\af0\dbch\af31505\loch\f0   int n;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter a number : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0   disp(n);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par \hich\af0\dbch\af31505\loch\f0 void disp(int x\hich\af0\dbch\af31505\loch\f0 )
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int i;
\par \hich\af0\dbch\af31505\loch\f0   for(i=1;i<=x;i++)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     printf("%d\\t",i);
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \}
\par 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Program :}{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0   fact_fn}{
\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 .c
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 To calculate factorial of given number
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0    unsigned long fact(int);
\par \hich\af0\dbch\af31505\loch\f0    int n;
\par \hich\af0\dbch\af31505\loch\f0    unsigned long f;
\par \hich\af0\dbch\af31505\loch\f0    clrscr();
\par \hich\af0\dbch\af31505\loch\f0    printf("Entr a number : ");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0    f=fact(n);
\par \hich\af0\dbch\af31505\loch\f0    printf("Factorial of %d : %lu",n,f);
\par \hich\af0\dbch\af31505\loch\f0    getch();
\par \}
\par \hich\af0\dbch\af31505\loch\f0 unsigned long fact(int x)
\par \{
\par \hich\af0\dbch\af31505\loch\f0   unsigned long f=1;
\par \hich\af0\dbch\af31505\loch\f0   while(x>=1)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     f=f*x;
\par \hich\af0\dbch\af31505\loch\f0     x--;
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   return f;
\par \}
\par 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Program :}{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0   rev_fn}{
\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 .c
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 To display reverse number of given number
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0    unsigned long rev(int);
\par \hich\af0\dbch\af31505\loch\f0    int n;
\par \hich\af0\dbch\af31505\loch\f0    unsigned long r;
\par \hich\af0\dbch\af31505\loch\f0    clrscr();
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter a number : ");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0    r=rev(n);
\par \hich\af0\dbch\af31505\loch\f0    printf("Reverse number of \hich\af0\dbch\af31505\loch\f0 %d : %lu",n,r);
\par \hich\af0\dbch\af31505\loch\f0    getch();
\par \}
\par \hich\af0\dbch\af31505\loch\f0 unsigned long rev(int x)
\par \{
\par \hich\af0\dbch\af31505\loch\f0   unsigned long r=0;
\par \hich\af0\dbch\af31505\loch\f0   while(x>0)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     r=r*10+(x%10);
\par \hich\af0\dbch\af31505\loch\f0     x=x/10;
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   return r;
\par \}
