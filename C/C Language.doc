\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   void fibo(int);
\par \hich\af0\dbch\af31505\loch\f0   int n;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter a number : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0   printf("Fibonacci series \\n");
\par \hich\af0\dbch\af31505\loch\f0   fibo(n);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par \hich\af0\dbch\af31505\loch\f0 void fibo(int x)
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int i,a=0,b=1,c;
\par \hich\af0\dbch\af31505\loch\f0   printf("%d\\t%d",a,b);
\par \hich\af0\dbch\af31505\loch\f0   for(i=1;i<=x-2;i++)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     c=a+b;
\par \hich\af0\dbch\af31505\loch\f0     printf("\\\hich\af0\dbch\af31505\loch\f0 t%d",c);
\par \hich\af0\dbch\af31505\loch\f0     a=b;
\par \hich\af0\dbch\af31505\loch\f0     b=c;
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \}
\par 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Program :}{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0   lcm_gcd}{
\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 .c
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 To find LCM and GCD of given numbers 
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0    int lcm(int,int);
\par \hich\af0\dbch\af31505\loch\f0    int gcd(int,int);
\par \hich\af0\dbch\af31505\loch\f0    int l,g,a,b;
\par \hich\af0\dbch\af31505\loch\f0    clrscr();
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter 2 numbers  : ");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d%d",&a,&b);
\par \hich\af0\dbch\af31505\loch\f0    l=lcm(a,b);
\par \hich\af0\dbch\af31505\loch\f0    g=gcd(a,b);
\par \hich\af0\dbch\af31505\loch\f0    printf("LCM of %d and %d : %d\\n",a,b,l);
\par \hich\af0\dbch\af31505\loch\f0    printf("GCD of %d and %d : %d",a,b,g);
\par \hich\af0\dbch\af31505\loch\f0    getch();
\par \}
\par \hich\af0\dbch\af31505\loch\f0 int lcm(int x,int y)
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int lm;
\par \hich\af0\dbch\af31505\loch\f0   if(x>y)
\par \hich\af0\dbch\af31505\loch\f0     lm=x;
\par \hich\af0\dbch\af31505\loch\f0   else
\par \hich\af0\dbch\af31505\loch\f0     lm=y;
\par \hich\af0\dbch\af31505\loch\f0   while(1)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     if(lm%x==0 &&\hich\af0\dbch\af31505\loch\f0  lm%y==0)
\par \hich\af0\dbch\af31505\loch\f0       break;
\par \hich\af0\dbch\af31505\loch\f0     lm++;
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   return lm;
\par \}
\par \hich\af0\dbch\af31505\loch\f0 int gcd(int x,int y)
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int gd,i;
\par \hich\af0\dbch\af31505\loch\f0   for(i=1;i<=x && i<=y;i++)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     if(x%i==0 && y%i==0)
\par \hich\af0\dbch\af31505\loch\f0        gd=i;
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   return gd;
\par \}
\par 
