\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   fp=fopen("a.txt","a+t");
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter data (Ctrl+Z to stop) : ");
\par \hich\af0\dbch\af31505\loch\f0   ch=getchar();
\par \hich\af0\dbch\af31505\loch\f0   while(ch!=EOF)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     putc(ch,fp);
\par \hich\af0\dbch\af31505\loch\f0     ch=getchar();
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nData stored successfully");
\par \hich\af0\dbch\af31505\loch\f0   rewind(fp);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\n\\nReading data from the file\\n\\n");
\par \hich\af0\dbch\af31505\loch\f0   ch=getc(fp);
\par \hich\af0\dbch\af31505\loch\f0   while(ch!=EOF)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     printf("%c",ch);
\par \hich\af0\dbch\af31505\loch\f0     ch=getc(fp);
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   fclose(fp);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par 
