\par \hich\af0\dbch\af31505\loch\f0     for(j=0;j<c;j++)
\par \hich\af0\dbch\af31505\loch\f0     \{
\par \hich\af0\dbch\af31505\loch\f0       scanf("%d",&a[i][j]);
\par \hich\af0\dbch\af31505\loch\f0     \}
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \}
\par \hich\af0\dbch\af31505\loch\f0 void disp(int a[][10],int r,int c)
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int i,j;
\par \hich\af0\dbch\af31505\loch\f0   for(i=0;i<r;i++)
