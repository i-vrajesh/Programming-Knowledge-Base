\par }{\rtlch\fcs1 \af44\afs44 \ltrch\fcs0 \f44\fs28\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\ai\af44\afs44 \ltrch\fcs0 \b\i\f44\fs28\insrsid11017018\charrsid13244520 \hich\af44\dbch\af31505\loch\f44 To enter any password and display the password string
\par }{\rtlch\fcs1 \af44\afs44 \ltrch\fcs0 \f44\fs28\insrsid11017018\charrsid13244520 
\par \hich\af44\dbch\af31505\loch\f44 #include<stdio.h>
\par \hich\af44\dbch\af31505\loch\f44 #include<conio.h>
\par \hich\af44\dbch\af31505\loch\f44 void main()
\par \{
\par \hich\af44\dbch\af31505\loch\f44    char st[20],ch;
\par \hich\af44\dbch\af31505\loch\f44    int i=0;
\par \hich\af44\dbch\af31505\loch\f44    clrscr();
\par \hich\af44\dbch\af31505\loch\f44    gotoxy(20,15);
\par \hich\af44\dbch\af31505\loch\f44    printf("Enter Password : ");
\par \hich\af44\dbch\af31505\loch\f44    while(1)
\par \hich\af44\dbch\af31505\loch\f44    \{
\par \hich\af44\dbch\af31505\loch\f44      ch=getch();
\par \hich\af44\dbch\af31505\loch\f44      if(ch==13)
\par \hich\af44\dbch\af31505\loch\f44        break;
\par \hich\af44\dbch\af31505\loch\f44      if(ch==8)
\par \hich\af44\dbch\af31505\loch\f44      \{
\par \hich\af44\dbch\af31505\loch\f44        if(i>0)
\par \hich\af44\dbch\af31505\loch\f44        \{
\par \hich\af44\dbch\af31505\loch\f44               printf("\\b%c\\b",32);
\par \hich\af44\dbch\af31505\loch\f44               i--;
\par \hich\af44\dbch\af31505\loch\f44        \}
\par \hich\af44\dbch\af31505\loch\f44      \}
\par \hich\af44\dbch\af31505\loch\f44      else
\par \hich\af44\dbch\af31505\loch\f44     
\par \hich\af44\dbch\af31505\loch\f44        st[i]=ch;
\par \hich\af44\dbch\af31505\loch\f44        i++;
\par \hich\af44\dbch\af31505\loch\f44        printf("*");
\par \hich\af44\dbch\af31505\loch\f44      \}
\par \hich\af44\dbch\af31505\loch\f44    \}
\par \hich\af44\dbch\af31505\loch\f44    st[i]='\\0';
\par \hich\af44\dbch\af31505\loch\f44    gotoxy(20,30);
\par \hich\af44\dbch\af31505\loch\f44    printf("Given String : %s",st);
\par \hich\af44\dbch\af31505\loch\f44    getch();
