\par }{\rtlch\fcs1 \ab\ai\af44\afs44 \ltrch\fcs0 \b\i\f44\fs28\insrsid11017018\charrsid13244520 \hich\af44\dbch\af31505\loch\f44 To find character frequency of given String
\par }{\rtlch\fcs1 \ab\af44\afs44 \ltrch\fcs0 \b\f44\fs28\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \af44\afs44 \ltrch\fcs0 \f44\fs28\insrsid11017018\charrsid13244520 \hich\af44\dbch\af31505\loch\f44 #include<stdio.h>
\par \hich\af44\dbch\af31505\loch\f44 #include<conio.h>
\par \hich\af44\dbch\af31505\loch\f44 void main()
\par \{
\par \hich\af44\dbch\af31505\loch\f44    static int a[256],i;
\par \hich\af44\dbch\af31505\loch\f44    char st[80];
\par \hich\af44\dbch\af31505\loch\f44    clrscr();
\par \hich\af44\dbch\af31505\loch\f44    printf("Enter a String : ");
\par \hich\af44\dbch\af31505\loch\f44    gets(st);
\par \hich\af44\dbch\af31505\loch\f44    for(i=0;i<strlen(st);i++)
\par \hich\af44\dbch\af31505\loch\f44    \{
\par \hich\af44\dbch\af31505\loch\f44      a[st[i]]=a[st[i]]+1;
\par \hich\af44\dbch\af31505\loch\f44    \}
\par \hich\af44\dbch\af31505\loch\f44    printf("\\nCharacter   Frequency");
\par \hich\af44\dbch\af31505\loch\f44    printf("\\n----------------------\\n");
\par \hich\af44\dbch\af31505\loch\f44    for(i=0;i<256;i++)
\par \hich\af44\dbch\af31505\loch\f44    \{
\par \hich\af44\dbch\af31505\loch\f44      if(a[i]!=0)
\par \hich\af44\dbch\af31505\loch\f44        printf("\\n%c    \hich\af44\dbch\af31505\loch\f44           %d",i,a[i]);
\par \hich\af44\dbch\af31505\loch\f44    \}
\par \hich\af44\dbch\af31505\loch\f44    getch();
\par \}
\par 
\par 
\par }{\rtlch\fcs1 \ab\af44\afs44 \ltrch\fcs0 \b\f44\fs28\ul\insrsid11017018\charrsid13244520 \hich\af44\dbch\af31505\loch\f44 Program :}{\rtlch\fcs1 \ab\af44\afs44 \ltrch\fcs0 \b\f44\fs28\insrsid11017018\charrsid13244520 \hich\af44\dbch\af31505\loch\f44 
