\par \hich\af0\dbch\af31505\loch\f0   else
\par \hich\af0\dbch\af31505\loch\f0     max=b;
\par \hich\af0\dbch\af31505\loch\f0   printf("Maximum value  : %d",max);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
