\par \hich\af0\dbch\af31505\loch\f0   int y,m,t;
\par \hich\af0\dbch\af31505\loch\f0   float p,r,si,tamt;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter principal amount           : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%f",&p);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter rate of interest           : ");
