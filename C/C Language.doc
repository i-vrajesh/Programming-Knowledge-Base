\par \hich\af0\dbch\af31505\loch\f0 void accept(int a[],int n)
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int i;
\par \hich\af0\dbch\af31505\loch\f0   for(i=0;i<n;i++)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     scanf("%d",&a[i]);
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \}
\par \hich\af0\dbch\af31505\loch\f0 void disp(int a[],int n)
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int i;
\par \hich\af0\dbch\af31505\loch\f0   for(i=0;i<n;i++)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     printf("\\t%d",a[i]);
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \}
\par \hich\af0\dbch\af31505\loch\f0 void sort(int a[],int n)
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int i,j,t;
\par \hich\af0\dbch\af31505\loch\f0   for(i=0;i<n-1;i++)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     for(j=i+1;j<n;j++)
\par \hich\af0\dbch\af31505\loch\f0     \{
\par \hich\af0\dbch\af31505\loch\f0       if(a[i]>a[j])
\par \hich\af0\dbch\af31505\loch\f0       \{
\par \hich\af0\dbch\af31505\loch\f0             t=a[i];
\par \hich\af0\dbch\af31505\loch\f0             a[i]=a[j];
\par \hich\af0\dbch\af31505\loch\f0             a[j]=t;
\par \hich\af0\dbch\af31505\loch\f0       \}
\par \hich\af0\dbch\af31505\loch\f0     \}
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \}
