\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 .c}{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 To enter current date and date of birth. Calculate and display present age .
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int cd,cm,cy,bd,bm,by,d,m,y;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter current date (dd-mm-yyyy) : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d-%d-%d",&cd,&cm,&cy);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter birth date (dd-mm-yyyy)   : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d-%d-%d",&bd,&bm,&by);
\par \hich\af0\dbch\af31505\loch\f0   d=cd-bd;
\par \hich\af0\dbch\af31505\loch\f0   m=cm-bm;
\par \hich\af0\dbch\af31505\loch\f0   y=cy-by;
\par \hich\af0\dbch\af31505\loch\f0   if(d<0)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0    \hich\af0\dbch\af31505\loch\f0  d=d+30;
\par \hich\af0\dbch\af31505\loch\f0     m--;
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   if(m<0)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     m=m+12;
\par \hich\af0\dbch\af31505\loch\f0     y--;
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   printf("Present age is : %d years %d months %d days",y,m,d);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 if-else statement :
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0     It is an extension of simple if statement.
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Syntax :
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0         if(expr)
\par \hich\af0\dbch\af31505\loch\f0        \{
\par \hich\af0\dbch\af31505\loch\f0         \hich\af0\dbch\af31505\loch\f0      Statements-1;
\par \hich\af0\dbch\af31505\loch\f0        \}
\par \hich\af0\dbch\af31505\loch\f0        else
\par \hich\af0\dbch\af31505\loch\f0        \{
\par \hich\af0\dbch\af31505\loch\f0              Statements-2;
\par \hich\af0\dbch\af31505\loch\f0        \}
\par \hich\af0\dbch\af31505\loch\f0       
\par \hich\af0\dbch\af31505\loch\f0     In this statement, first the expression will be evaluated, and if it is true then the if block statements are executed and the else block statements are\hich\af0\dbch\af31505\loch\f0 
 ignored. Otherwise if the expression is false, then else block statements are executed and if block statements are ignored.
\par 
