\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     printf("\\nFile not found");
\par \hich\af0\dbch\af31505\loch\f0     getch();
\par \hich\af0\dbch\af31505\loch\f0     exit(0);
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   printf("\\n\\nReading data from the file\\n\\n");
\par \hich\af0\dbch\af31505\loch\f0   ch=getc(fp);
