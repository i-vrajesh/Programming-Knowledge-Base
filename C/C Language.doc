\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0    int n,i,j,sum=0;
\par \hich\af0\dbch\af31505\loch\f0    clrscr();
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter a number : ");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0    printf("Perfect Numbers between 1 and %d : ",n);
\par \hich\af0\dbch\af31505\loch\f0    for(i=1;i<=n;i++)
\par \hich\af0\dbch\af31505\loch\f0    \{
\par \hich\af0\dbch\af31505\loch\f0      sum=0;
\par \hich\af0\dbch\af31505\loch\f0      for(j=1;j<=i/2;j++)
\par \hich\af0\dbch\af31505\loch\f0      \{
\par \hich\af0\dbch\af31505\loch\f0          if(i%j==0)
\par \hich\af0\dbch\af31505\loch\f0            sum=sum+j;
\par \hich\af0\dbch\af31505\loch\f0      \}
\par \hich\af0\dbch\af31505\loch\f0      if(sum==i)
\par \hich\af0\dbch\af31505\loch\f0        printf("\\t%d",i);
\par \hich\af0\dbch\af31505\loch\f0    \}
\par \hich\af0\dbch\af31505\loch\f0    getch();
\par \}
\par 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Program :}{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0   armst_nl}{
