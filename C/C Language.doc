\par \hich\af44\dbch\af31505\loch\f44 #include<stdio.h>
\par \hich\af44\dbch\af31505\loch\f44 #include<conio.h>
\par \hich\af44\dbch\af31505\loch\f44 //#define square(x) x*x
\par \hich\af44\dbch\af31505\loch\f44 //#define square(x) (x*x)
\par 
\par \hich\af44\dbch\af31505\loch\f44 void main()
\par \{
\par \hich\af44\dbch\af31505\loch\f44   int n;
\par \hich\af44\dbch\af31505\loch\f44   n=100/square(5);
\par \hich\af44\dbch\af31505\loch\f44   printf("n = %d",n);
\par \hich\af44\dbch\af31505\loch\f44   getch();
\par \}
\par 
\par \hich\af44\dbch\af31505\loch\f44 In the above example, if we gives 
\par \hich\af44\dbch\af31505\loch\f44      n=100/square(5), we should get 100(according to macros). Because it is a precpcessor statement and it replaces its definition. i.e. according to macro definition,
\par \hich\af44\dbch\af31505\loch\f44       100/square(\hich\af44\dbch\af31505\loch\f44 5) means 100/5*5=20*5=100.
\par \hich\af44\dbch\af31505\loch\f44 According to function definition,
\par \hich\af44\dbch\af31505\loch\f44       100/square(5) means 100/25=4 
\par \hich\af44\dbch\af31505\loch\f44 Hence the difference between macro and a function is in macros, the method name is replaced with its definition. i.e. square(a) is replaced with 5*5. whereas i\hich\af44\dbch\af31505\loch\f44 
n functions, the method is replaced with its value. i.e. square(5) is replaced with the value 25.
\par 
\par \hich\af44\dbch\af31505\loch\f44 If we want to get the result of 4, we should give 
\par \hich\af44\dbch\af31505\loch\f44          n = 100/(square(5))  
\par \hich\af44\dbch\af31505\loch\f44                     or 
\par \hich\af44\dbch\af31505\loch\f44 in the macro definition we should give #define squa\hich\af44\dbch\af31505\loch\f44 re(a) (a*a)
\par \hich\af44\dbch\af31505\loch\f44   then,    res  = 100/(25)
\par \hich\af44\dbch\af31505\loch\f44                     = 4 
\par 
\par }\pard \ltrpar\qj \li0\ri0\nowidctlpar\tx2310\wrapdefault\faauto\rin0\lin0\itap0 {\rtlch\fcs1 \ab\af44\afs44 \ltrch\fcs0 \b\f44\fs28\ul\insrsid11017018\charrsid13244520 \hich\af44\dbch\af31505\loch\f44 Program :}{\rtlch\fcs1 \ab\af44\afs44 \ltrch\fcs0 
