\par \hich\af0\dbch\af31505\loch\f0  \hich\af0\dbch\af31505\loch\f0  void disp(int [],int);
\par \hich\af0\dbch\af31505\loch\f0    int a[20],n;
\par \hich\af0\dbch\af31505\loch\f0    clrscr();
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter number of elements : ");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter Elements : ");
\par \hich\af0\dbch\af31505\loch\f0    accept(a,n);
\par \hich\af0\dbch\af31505\loch\f0    printf("Given Elements : ");
\par \hich\af0\dbch\af31505\loch\f0    disp(a,n);
\par \hich\af0\dbch\af31505\loch\f0    getch();
\par \}
\par \hich\af0\dbch\af31505\loch\f0 void accept(int x[],int s)
