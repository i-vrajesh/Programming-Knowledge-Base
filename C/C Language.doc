\par }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 To display Armstrong numbers from 1 to given number 
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0    int n,m,r,arm,i;
\par \hich\af0\dbch\af31505\loch\f0    clrscr();
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter a number : ");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0    printf("Armstrong numbers from 1 to %d : \\n",n);
\par \hich\af0\dbch\af31505\loch\f0    for(i=1;i<=n;i++)
\par \hich\af0\dbch\af31505\loch\f0    \{
\par \hich\af0\dbch\af31505\loch\f0      arm=0;
\par \hich\af0\dbch\af31505\loch\f0      m=i;
\par \hich\af0\dbch\af31505\loch\f0      while(m>0)
\par \hich\af0\dbch\af31505\loch\f0      \{
\par \hich\af0\dbch\af31505\loch\f0          r=m%10;
\par \hich\af0\dbch\af31505\loch\f0          arm=arm+(r*r*r);
\par \hich\af0\dbch\af31505\loch\f0          m=m/10;
\par \hich\af0\dbch\af31505\loch\f0      \}
\par \hich\af0\dbch\af31505\loch\f0      if(arm==i)
\par \hich\af0\dbch\af31505\loch\f0      printf("\\t%d",i);
\par \hich\af0\dbch\af31505\loch\f0    \}
\par \hich\af0\dbch\af31505\loch\f0    getch();
\par \}
\par 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Program :}{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0   prm_fact}{
