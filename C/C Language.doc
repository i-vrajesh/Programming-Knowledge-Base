\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   void accept(int *);
\par \hich\af0\dbch\af31505\loch\f0   int n;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   accept(&n);
\par \hich\af0\dbch\af31505\loch\f0   printf("Given value = %d",n);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par \hich\af0\dbch\af31505\loch\f0 void accept(int *p)
\par \{
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter a value : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",\hich\af0\dbch\af31505\loch\f0 p);
