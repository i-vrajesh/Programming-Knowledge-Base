\par \{
\par \hich\af0\dbch\af31505\loch\f0   char ch;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter any character : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%c",&ch);
\par \hich\af0\dbch\af31505\loch\f0   if((ch>='a' && ch<='z') || (ch>='A' && ch<='Z'))
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     if(ch=='a' || ch=='A' || ch=='e' || ch=='E'\hich\af0\dbch\af31505\loch\f0  || ch=='i'|| ch=='I' || ch=='o' ||     
\par \hich\af0\dbch\af31505\loch\f0                                                            ch=='O' || ch=='u' || ch=='U')
\par \hich\af0\dbch\af31505\loch\f0        printf("Given character is a vowel");
\par \hich\af0\dbch\af31505\loch\f0     else
