\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0    int a,b;
\par \hich\af0\dbch\af31505\loch\f0    char opt;
\par \hich\af0\dbch\af31505\loch\f0    clrscr();
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter 2 numbers : ");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d%d",&a,&b);
\par \hich\af0\dbch\af31505\loch\f0    printf("A-Addition\\nS-Subtraction\\nM-Multiplication\\nD-Division
\par \hich\af0\dbch\af31505\loch\f0        \\nR-Modulus\\nEnter your option : ");
\par \hich\af0\dbch\af31505\loch\f0    fflush(stdin);
\par \hich\af0\dbch\af31505\loch\f0    scanf("%c",&opt);
\par \hich\af0\dbch\af31505\loch\f0    switch(o\hich\af0\dbch\af31505\loch\f0 pt)
\par \hich\af0\dbch\af31505\loch\f0    \{
\par \hich\af0\dbch\af31505\loch\f0       case 'A':
\par \hich\af0\dbch\af31505\loch\f0       case 'a':
\par \hich\af0\dbch\af31505\loch\f0         
\par \hich\af0\dbch\af31505\loch\f0         printf("Addition of %d and %d is %d",a,b,a+b);
\par \hich\af0\dbch\af31505\loch\f0         break;
\par 
\par \hich\af0\dbch\af31505\loch\f0       case 'S':
\par \hich\af0\dbch\af31505\loch\f0       case 's':
\par \hich\af0\dbch\af31505\loch\f0           printf( "Subtraction of %d and %d is %d",a,b,a-b);
\par \hich\af0\dbch\af31505\loch\f0           break;
\par 
\par \hich\af0\dbch\af31505\loch\f0       case 'M':
\par \hich\af0\dbch\af31505\loch\f0       ca\hich\af0\dbch\af31505\loch\f0 se 'm':
\par \hich\af0\dbch\af31505\loch\f0            printf("Multiplication of %d and %d is %d",a,b,a*b);
\par \hich\af0\dbch\af31505\loch\f0            break;
\par 
\par \hich\af0\dbch\af31505\loch\f0       case 'D':
\par \hich\af0\dbch\af31505\loch\f0       case 'd':
\par \hich\af0\dbch\af31505\loch\f0            printf("Division of %d and %d is %d",a,b,a/b);
\par \hich\af0\dbch\af31505\loch\f0            break;
\par 
\par \hich\af0\dbch\af31505\loch\f0       case 'R':
\par \hich\af0\dbch\af31505\loch\f0       case 'r':
\par \hich\af0\dbch\af31505\loch\f0            printf("Modul\hich\af0\dbch\af31505\loch\f0 us of %d and %d is %d",a,b,a%b);
\par \hich\af0\dbch\af31505\loch\f0            break;
\par 
\par \hich\af0\dbch\af31505\loch\f0       default:
\par \hich\af0\dbch\af31505\loch\f0            printf("Invalid Option");
\par \hich\af0\dbch\af31505\loch\f0    \}
\par \hich\af0\dbch\af31505\loch\f0    getch();
\par \}
\par 
