\par }{\rtlch\fcs1 \af44\afs32 \ltrch\fcs0 \f44\fs20\insrsid11017018\charrsid13244520 
\par \hich\af44\dbch\af31505\loch\f44 #include<stdio.h>
\par \hich\af44\dbch\af31505\loch\f44 #include<conio.h>
\par \hich\af44\dbch\af31505\loch\f44 #include<string.h>
\par \hich\af44\dbch\af31505\loch\f44 void main()
\par \{
\par \hich\af44\dbch\af31505\loch\f44   char s1[80],s2[80];
\par \hich\af44\dbch\af31505\loch\f44   int n;
\par \hich\af44\dbch\af31505\loch\f44   clrscr();
\par \hich\af44\dbch\af31505\loch\f44   printf("Enter a string : ");
\par \hich\af44\dbch\af31505\loch\f44   gets(s1);
\par \hich\af44\dbch\af31505\loch\f44   strcpy(s2,s1);
\par \hich\af44\dbch\af31505\loch\f44   strrev(s2);
\par \hich\af44\dbch\af31505\loch\f44   n=strcmp(s1,s2);
\par \hich\af44\dbch\af31505\loch\f44   if(n==0)
\par \hich\af44\dbch\af31505\loch\f44     printf("\\nGiven string is a Palindrome");
\par \hich\af44\dbch\af31505\loch\f44   else
\par \hich\af44\dbch\af31505\loch\f44     p\hich\af44\dbch\af31505\loch\f44 rintf("\\nGiven string is not a Palindrome");
\par \hich\af44\dbch\af31505\loch\f44   getch();
\par \}
