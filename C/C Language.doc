\par \hich\af0\dbch\af31505\loch\f0 void main(int argc,char *argv[])
\par \{
\par \hich\af0\dbch\af31505\loch\f0   FILE *fp;
\par \hich\af0\dbch\af31505\loch\f0   char ch;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   if(argc!=2)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     printf("Invalid arguments");
