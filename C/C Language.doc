\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0    int n,i=1,count=0;
\par \hich\af0\dbch\af31505\loch\f0    clrscr();
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter a number : ");
\par \hich\af0\dbch\af31505\loch\f0    \hich\af0\dbch\af31505\loch\f0 scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0    while(i<=n)
\par \hich\af0\dbch\af31505\loch\f0    \{
\par \hich\af0\dbch\af31505\loch\f0      if(n%i==0)
\par \hich\af0\dbch\af31505\loch\f0        count++;
\par \hich\af0\dbch\af31505\loch\f0      i++;
\par \hich\af0\dbch\af31505\loch\f0    \}
\par \hich\af0\dbch\af31505\loch\f0    if(count==2)
\par \hich\af0\dbch\af31505\loch\f0      printf("Given number is Prime");
\par \hich\af0\dbch\af31505\loch\f0    else
\par \hich\af0\dbch\af31505\loch\f0      printf("Given numbr is not Prime");
\par \hich\af0\dbch\af31505\loch\f0    getch();
\par \}
