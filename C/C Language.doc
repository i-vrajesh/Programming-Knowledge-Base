\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void\hich\af0\dbch\af31505\loch\f0  main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int n,i,sum=0;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter a number : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0   for(i=1;i<=n/2;i++)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     if(n%i==0)
\par \hich\af0\dbch\af31505\loch\f0       sum=sum+i;
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   if(n==sum)
\par \hich\af0\dbch\af31505\loch\f0     printf("Given number is Perfect number");
\par \hich\af0\dbch\af31505\loch\f0   else
\par \hich\af0\dbch\af31505\loch\f0     printf("Given number is not Perfect number");
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
