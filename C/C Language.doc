\par \{
\par \hich\af0\dbch\af31505\loch\f0    int n,i=2,k=1;
\par \hich\af0\dbch\af31505\loch\f0    clrscr();
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter a number : ");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0    while(k<=2)
\par \hich\af0\dbch\af31505\loch\f0    \{
\par \hich\af0\dbch\af31505\loch\f0       if(i==2)
\par \hich\af0\dbch\af31505\loch\f0          printf("Even numbers from 1 to %d",n);
\par \hich\af0\dbch\af31505\loch\f0       if(i==1)
\par \hich\af0\dbch\af31505\loch\f0         printf("Odd numbers from 1 to %d",n);
\par \hich\af0\dbch\af31505\loch\f0       printf("%d\\t",i);
\par \hich\af0\dbch\af31505\loch\f0       i=i+2;
\par \hich\af0\dbch\af31505\loch\f0       if(i>n)
\par \hich\af0\dbch\af31505\loch\f0       \{
\par \hich\af0\dbch\af31505\loch\f0           i=1;
\par \hich\af0\dbch\af31505\loch\f0           k++;
\par \hich\af0\dbch\af31505\loch\f0       \}
\par \hich\af0\dbch\af31505\loch\f0    \}
\par \}
