\par }\pard \ltrpar\qj \li0\ri0\nowidctlpar\wrapdefault\faauto\rin0\lin0\itap0 {\rtlch\fcs1 \af44\afs44 \ltrch\fcs0 \f44\fs28\insrsid11017018\charrsid13244520 
