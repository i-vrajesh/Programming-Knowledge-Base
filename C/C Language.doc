\par \hich\af0\dbch\af31505\loch\f0    int n1,n2,i,j,count;
\par \hich\af0\dbch\af31505\loch\f0    clrscr();
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter starting number : ");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d",&n1);
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter ending number   : ");
