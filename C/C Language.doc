\par }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Swaping of 2 values using call by reference
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   void swap(int *,int *);
\par \hich\af0\dbch\af31505\loch\f0   int a,b;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter 2 values : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d%d",&a,&b);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\\hich\af0\dbch\af31505\loch\f0 nGiven values before swaping : ");
\par \hich\af0\dbch\af31505\loch\f0   printf("\\na=%d",a);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nb=%d",b);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\n\\nGiven values after swaping : ");
\par \hich\af0\dbch\af31505\loch\f0   swap(&a,&b);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\na=%d",a);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nb=%d",b);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par \hich\af0\dbch\af31505\loch\f0 void swap(int *x,int *y)
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int t;
\par \hich\af0\dbch\af31505\loch\f0   t=*x;
\par \hich\af0\dbch\af31505\loch\f0   *x=*y;
\par \hich\af0\dbch\af31505\loch\f0   *y=\hich\af0\dbch\af31505\loch\f0 t;
\par \}
\par 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Pointers and Arrays :
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 
    When an array is declared, the compiler allocates a base address and sufficient amount of storage to contain all the elements of array in continuous memory locations. The base address is the location of the first element (in
\hich\af0\dbch\af31505\loch\f0 dex = 0 ) of the array. The compiler also defines the array name as a constant pointer to the first element.
\par 
\par 
\par 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Program :}{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0   ptrarr1.c

\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int a[5];
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Base address : %u",&a[0]);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\\hich\af0\dbch\af31505\loch\f0 nBase address : %u",a);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par 
\par \hich\af0\dbch\af31505\loch\f0         Suppose we declare an array }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 a}{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 
\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0  as follows :-
\par \hich\af0\dbch\af31505\loch\f0                int a[5] = \{1,2,3,4,5\};
\par \hich\af0\dbch\af31505\loch\f0    Suppose the base address of a=1000 and each integer requires 2 bytes of memory,the 5 elements will be stored as follows :-
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par \hich\af0\dbch\af31505\loch\f0      The name 'a' is defined as a constant pointer pointing to the first element a[0] and therefore the value of a is 1000, the location where a[0] is stored.
\par \hich\af0\dbch\af31505\loch\f0 Hence  a= &a[0] = 1000
\par 
\par 
\par 
\par 
\par 
\par 
\par \hich\af0\dbch\af31505\loch\f0      If we declare }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 p}{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\hich\af0\dbch\af31505\loch\f0  as an integer pointer, then we can mak\hich\af0\dbch\af31505\loch\f0 e the pointer p to point to the array }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 
\hich\af0\dbch\af31505\loch\f0 a}{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0  by the following assignment.
\par \hich\af0\dbch\af31505\loch\f0       int *p;
\par \hich\af0\dbch\af31505\loch\f0       p = a ;  (or)  p = &a[0];
\par 
\par \hich\af0\dbch\af31505\loch\f0     Now we can access every element of }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 a}{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 
\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 \hich\f0  using p++ or p+0, p+1, \'85\loch\f0 .. to move one element to another. The relationship between }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 
\b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 p}{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0  and }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 
\b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 a}{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0  is shown below.
\par \hich\af0\dbch\af31505\loch\f0   
\par \hich\af0\dbch\af31505\loch\f0            p+0 = &a[0] = 1000
\par \hich\af0\dbch\af31505\loch\f0            p+1 = &a[1] = 1002
\par \hich\af0\dbch\af31505\loch\f0            p+2 = &a[2] = 1004
\par \hich\af0\dbch\af31505\loch\f0            p+3 = &a[3] = 1006
\par \hich\af0\dbch\af31505\loch\f0            p+4 = &a[4] = 1008
\par 
\par \hich\af0\dbch\af31505\loch\f0   When handling arrays instead of using array index we can use pointers to access arr\hich\af0\dbch\af31505\loch\f0 ay elements. 
\par \hich\af0\dbch\af31505\loch\f0 Note that
\par \hich\af0\dbch\af31505\loch\f0  *(p+i) gives the value of a[i].         
\par 
\par \hich\af0\dbch\af31505\loch\f0    To get the values of array elements :
\par \hich\af0\dbch\af31505\loch\f0           *( p+0) = a[0] = 1
\par \hich\af0\dbch\af31505\loch\f0            *(p+1) = a[1] = 2
\par \hich\af0\dbch\af31505\loch\f0            *(p+2)= a[2] = 3
\par \hich\af0\dbch\af31505\loch\f0            *(p+3)= a[3] = 4
\par \hich\af0\dbch\af31505\loch\f0            *(p+4) = a[4] = 5
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Note \hich\af0\dbch\af31505\loch\f0 :
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 The pointer accessing method is much faster than array indexing.
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Program :}{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0   ptrarr2.c

\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 To accept Single dimension array and display array elements using pointer accessing method
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int a[20],n,i,*p;
\par \hich\af0\dbch\af31505\loch\f0   p=a;    //p=&a[0];
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter number of elements : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter array elements : ");
\par \hich\af0\dbch\af31505\loch\f0   for(i=0;i<n;i++)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     scanf("%d",(p+i)); 
\par \hich\af0\dbch\af31505\loch\f0       
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nGiven array elements : ");
\par \hich\af0\dbch\af31505\loch\f0   for(i=0;\hich\af0\dbch\af31505\loch\f0 i<n;i++)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     printf("%d\\t",*(p+i));   
\par \hich\af0\dbch\af31505\loch\f0       
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par 
\par 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Pointers and Strings
\par 
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0  A pointer can also point to a string .
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Program :}{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0   ptrstr1.c

\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   char *st;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter a String : ");
\par \hich\af0\dbch\af31505\loch\f0   gets(st);
\par \hich\af0\dbch\af31505\loch\f0   printf("Given String : %s",st);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par 
\par \tab \hich\af0\dbch\af31505\loch\f0 We need not specify the size of String, the compiler 
\par \hich\af0\dbch\af31505\loch\f0                                   automatically allocates sufficient amount of memory
\par 
\par 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 String copying using P\hich\af0\dbch\af31505\loch\f0 ointers :
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Program :}{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0   ptrstr2.c

\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   char *st1,*st2;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter a String : ");
\par \hich\af0\dbch\af31505\loch\f0   gets(st1);
\par \hich\af0\dbch\af31505\loch\f0   st2=st1;
\par \hich\af0\dbch\af31505\loch\f0   printf("Given String   : %s",st1);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nCopied String  : %s",st2);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Dynamic Memory Allocation(DMA) :
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 
   C language requires the number of elements in an array to be specified at compile time. But we may not be able to do so always. Our initial judgement of size, if it is wrong may cause failure of program or wastage of m\hich\af0\dbch\af31505\loch\f0 
emory space. At this situation we can use DMA.
\par 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Definition :
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0       The process of allocating memory at run time is known as }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 
\b\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Dynamic Memory Allocation (DMA).
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 malloc :}{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0     <alloc.h>

\par 
\par \hich\af0\dbch\af31505\loch\f0    It is used to allocate memory at runtime.
