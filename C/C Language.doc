\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 .c
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 To find area of given triangle with 3 sides 
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<math.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   float a,b,c,s,area;
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter sides of a triangle : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%f%f%f",&a,&b,&c);
\par \hich\af0\dbch\af31505\loch\f0   if(a+b<=c || a+c<=b || b+c<=a)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     printf("unable to form a triangle");
\par \hich\af0\dbch\af31505\loch\f0     getch();
\par \hich\af0\dbch\af31505\loch\f0     exit(0);
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   s=(a+b+c)/2;
\par \hich\af0\dbch\af31505\loch\f0   area=sqrt(s*(s-a)*(s-b)*(s-c));
\par \hich\af0\dbch\af31505\loch\f0   printf("Area of triangle = %.2f sq units",area);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Program :}{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0   compound}{
\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 .c
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 To enter principal amount, rate of interest and time, then calculate total amount with compound interest 
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<math.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int y,m,n;
\par \hich\af0\dbch\af31505\loch\f0   float p,r,i,tot;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter Principal Amount       \hich\af0\dbch\af31505\loch\f0 : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%f",&p);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter Rate of Interest       : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%f",&r);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter time(years and months) : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d%d",&y,&m);
\par \hich\af0\dbch\af31505\loch\f0   n=y*12+m;
\par \hich\af0\dbch\af31505\loch\f0   tot=p*pow(1+(r/100),n);
\par \hich\af0\dbch\af31505\loch\f0   i=tot-p;
\par \hich\af0\dbch\af31505\loch\f0   printf("Interest     : %.2f",i);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nTotal\hich\af0\dbch\af31505\loch\f0  Amount : %.2f",tot);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Program :}{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0   sim}{
\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 _ser.c
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Evaluate the following simple series
\par \hich\af0\dbch\af31505\loch\f0      1 + 1/2 + 1/3 + 1/4 + ............. +1/n 
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int i,n;
\par \hich\af0\dbch\af31505\loch\f0   float sum=0;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter a number : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0   for(i=1;i<=n;i++)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     sum=sum+(float)1/i;
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   printf("Sum = %.2f",sum);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Program :}{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0   exp}{
\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 _ser.c
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0  Evaluate the following exponential series
\par \hich\af0\dbch\af31505\loch\f0     1 + x + (x power 2 )/fact(2) + (x power 3)/f\hich\af0\dbch\af31505\loch\f0 act(3) + ............... +
\par \hich\af0\dbch\af31505\loch\f0             (x power n)/fact(n) 
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<math.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0    unsigned long fact(int);
\par \hich\af0\dbch\af31505\loch\f0    int i,x,n;
\par \hich\af0\dbch\af31505\loch\f0    float sum=0;
\par \hich\af0\dbch\af31505\loch\f0    clrscr();
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter a value of x and n : ");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d%d",&x,&n);
\par \hich\af0\dbch\af31505\loch\f0    for(i=1;i<=n;i++)
\par \hich\af0\dbch\af31505\loch\f0    \{
\par \hich\af0\dbch\af31505\loch\f0      sum=sum+pow(x,i)/fact(i);
