\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<string.h>
\par 
\par \hich\af0\dbch\af31505\loch\f0 struct student
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int sno,c,cpp,java,tot;
\par \hich\af0\dbch\af31505\loch\f0   char sname[20],res[10],gr;
\par \hich\af0\dbch\af31505\loch\f0   float avg;
\par \hich\af0\dbch\af31505\loch\f0  \};
\par 
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   s\hich\af0\dbch\af31505\loch\f0 truct student s[100];
\par \hich\af0\dbch\af31505\loch\f0   int id=0,i;
\par \hich\af0\dbch\af31505\loch\f0   char ch;
\par \hich\af0\dbch\af31505\loch\f0   do
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0    clrscr();
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter Student Number :");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d",&s[id].sno);
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter Student Name  :");
\par \hich\af0\dbch\af31505\loch\f0    fflush(stdin);
\par \hich\af0\dbch\af31505\loch\f0    gets(s[id].sname);
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter Marks in C,Cpp and Java  :");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d%d%d",&s[id].c,&s[id].cpp,&s[id].java);
\par \hich\af0\dbch\af31505\loch\f0    s[id].tot=s[id].c+s[id].cpp+s[id].java;
\par \hich\af0\dbch\af31505\loch\f0    s[id].avg=(float)s[id].tot/3;
\par \hich\af0\dbch\af31505\loch\f0   if(s[id].c>=50 && s[id].cpp>=50 && s[id].java>=50)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     strcpy(s[id].res,"Pass");
\par \hich\af0\dbch\af31505\loch\f0     if(s[id].avg>=60)
\par \hich\af0\dbch\af31505\loch\f0       s[id].gr='A';
\par \hich\af0\dbch\af31505\loch\f0     else
\par \hich\af0\dbch\af31505\loch\f0       s[id].gr='B';
\par \hich\af0\dbch\af31505\loch\f0    \}
\par \hich\af0\dbch\af31505\loch\f0   else
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0    strcpy(s[id].res,"Fail");
\par \hich\af0\dbch\af31505\loch\f0    s[id].gr='-';
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   id++;
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter Another Record(y/n) :");
\par \hich\af0\dbch\af31505\loch\f0   fflush(stdin);
\par \hich\af0\dbch\af31505\loch\f0   scanf("%c",&ch);
\par \hich\af0\dbch\af31505\loch\f0  \}while(ch!='n' && id<100);
\par 
\par \hich\af0\dbch\af31505\loch\f0 for(i=0;i<id;i++)
\par \{
\par \hich\af0\dbch\af31505\loch\f0  clrscr();
\par \hich\af0\dbch\af31505\loch\f0  printf("\\\hich\af0\dbch\af31505\loch\f0 nRecord Number :%d",i+1);
\par \hich\af0\dbch\af31505\loch\f0  printf("\\nStudent Number    :%d",s[i].sno);
\par \hich\af0\dbch\af31505\loch\f0  printf("\\nStudent Name       :%s",s[i].sname);
\par \hich\af0\dbch\af31505\loch\f0  printf("\\nMarks in C           :%d",s[i].c);
\par \hich\af0\dbch\af31505\loch\f0  printf("\\nMarks in Cpp       :%d",s[i].cpp);
\par \hich\af0\dbch\af31505\loch\f0  printf("\\nMarks in Java       :%d",s[i].java\hich\af0\dbch\af31505\loch\f0 );
\par \hich\af0\dbch\af31505\loch\f0  printf("\\nTotal Marks         :%d",s[i].tot);
\par \hich\af0\dbch\af31505\loch\f0  printf("\\nAverage               :%.2f",s[i].avg);
\par \hich\af0\dbch\af31505\loch\f0  printf("\\nResult                  :%s",s[i].res);
\par \hich\af0\dbch\af31505\loch\f0  printf("\\nGrade                   :%c",s[i].gr);
\par \hich\af0\dbch\af31505\loch\f0  printf("\\n\\nPress Any Key...........");
\par \hich\af0\dbch\af31505\loch\f0  getch();
\par \hich\af0\dbch\af31505\loch\f0  \}
\par \}
