\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0    int n,count=0;
\par \hich\af0\dbch\af31505\loch\f0    unsigned long rev=0;
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter a number : ");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0    while(n>0)
\par \hich\af0\dbch\af31505\loch\f0    \{
\par \hich\af0\dbch\af31505\loch\f0       rev=(rev*10)+(n%10);
\par \hich\af0\dbch\af31505\loch\f0       n=n/10;
\par \hich\af0\dbch\af31505\loch\f0       count++;
\par \hich\af0\dbch\af31505\loch\f0    \}
\par \hich\af0\dbch\af31505\loch\f0    printf("Reverse number of given number : %*lu",count,rev);
\par \hich\af0\dbch\af31505\loch\f0    getch();
\par \}
\par 
\par \hich\af0\dbch\af31505\loch\f0 If n=1000, then we will get the reverse number as 1, i.e. zeros are not displayed, if we use the above format, the compiler will format it and gives the output as 0001, this is b\hich\af0\dbch\af31505\loch\f0 
ecause the number of digits in the given number, i.e. count = 4 and the value of this count is assigned to *, and hence the output have 4 digits. i.e. 0001 in case of n=1000
\par 
