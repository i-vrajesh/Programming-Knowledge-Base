\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   while(ch!='n');
\par \hich\af0\dbch\af31505\loch\f0   fseek(fp,0,0);
\par \hich\af0\dbch\af31505\loch\f0   fread(&s,sizeof(s),1,fp);
\par \hich\af0\dbch\af31505\loch\f0   while(!feof(fp))
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     clrscr();
