\par \hich\af0\dbch\af31505\loch\f0 Example }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 : nest_if.c}{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 
\b\f0\fs24\ul\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 To find maximum of 3 numbers using nested if 
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int a,b,c,max;
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter any three  numbers : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d%d%d",&a,&b,&c);
\par \hich\af0\dbch\af31505\loch\f0   if(a>b)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     if(a>c)
\par \hich\af0\dbch\af31505\loch\f0       max=a;
\par \hich\af0\dbch\af31505\loch\f0     else
\par \hich\af0\dbch\af31505\loch\f0       max=c;
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   else
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     if(b>c)
\par \hich\af0\dbch\af31505\loch\f0        max=b;
\par \hich\af0\dbch\af31505\loch\f0     else
\par \hich\af0\dbch\af31505\loch\f0       max=c;
