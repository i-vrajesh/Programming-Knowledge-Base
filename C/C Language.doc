\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int n;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter value of n : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0   if(n==1)
\par \hich\af0\dbch\af31505\loch\f0     goto lb1;
\par \hich\af0\dbch\af31505\loch\f0   if(n==2)
\par \hich\af0\dbch\af31505\loch\f0     goto lb2;
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nWelcome");
\par \hich\af0\dbch\af31505\loch\f0   \hich\af0\dbch\af31505\loch\f0 goto lb;
\par \hich\af0\dbch\af31505\loch\f0   lb1:
\par \hich\af0\dbch\af31505\loch\f0     printf("\\nLabel 1");
\par \hich\af0\dbch\af31505\loch\f0     goto lb;
\par \hich\af0\dbch\af31505\loch\f0   lb2:
\par \hich\af0\dbch\af31505\loch\f0     printf("\\nLabel 2");
\par \hich\af0\dbch\af31505\loch\f0     lb:
\par \hich\af0\dbch\af31505\loch\f0   getch();
