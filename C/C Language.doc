\par \hich\af0\dbch\af31505\loch\f0   fp=fopen("a.dat","a+b");  // append in binary format
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter data (0 to stop) : \\n\\n");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0   while(n!=0)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     putw(n,fp);
\par \hich\af0\dbch\af31505\loch\f0     scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   fseek(fp,0,0);  //rewind(fp);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\n\\nReading data from file : \\n\\n");
\par \hich\af0\dbch\af31505\loch\f0   n\hich\af0\dbch\af31505\loch\f0 =getw(fp);
\par \hich\af0\dbch\af31505\loch\f0   while(!feof(fp))
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     printf("%d\\n",n);
\par \hich\af0\dbch\af31505\loch\f0     n=getw(fp);
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   fclose(fp);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
