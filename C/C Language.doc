\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   FILE *fp;
\par \hich\af0\dbch\af31505\loch\f0   char st[80];
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   fp=fopen("str.txt","a+t");
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter string data ('end' to stop) : ");
\par \hich\af0\dbch\af31505\loch\f0   gets(st);
\par \hich\af0\dbch\af31505\loch\f0   while(strcmp(st,"end")!=0)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     fputs(st,fp);
\par \hich\af0\dbch\af31505\loch\f0     fputs("\\\hich\af0\dbch\af31505\loch\f0 n",fp);
\par \hich\af0\dbch\af31505\loch\f0     gets(st);
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0    rewind(fp);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nReading data from the file :\\n");
\par \hich\af0\dbch\af31505\loch\f0   fgets(st,80,fp);
\par \hich\af0\dbch\af31505\loch\f0   while(!feof(fp))
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     printf("%s",st);
\par \hich\af0\dbch\af31505\loch\f0     fgets(st,80,fp);
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \hich\af0\dbch\af31505\loch\f0   fclose(fp);
