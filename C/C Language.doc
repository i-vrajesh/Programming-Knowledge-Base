\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0    int a[20],n,i,se,ck=0;
\par \hich\af0\dbch\af31505\loch\f0    clrscr();
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter number of Elements : ");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0    printf("\\nEn\hich\af0\dbch\af31505\loch\f0 ter Elements \\n\\n");
\par \hich\af0\dbch\af31505\loch\f0    for(i=0;i<n;i++)
\par \hich\af0\dbch\af31505\loch\f0    \{
\par \hich\af0\dbch\af31505\loch\f0       printf("Enter element in a[%d] : ",i);
\par \hich\af0\dbch\af31505\loch\f0       scanf("%d",&a[i]);
\par \hich\af0\dbch\af31505\loch\f0    \}
\par \hich\af0\dbch\af31505\loch\f0    printf("\\n\\nEnter Element to Search : ");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d",&se);
\par \hich\af0\dbch\af31505\loch\f0    for(i=0;i<n;i++)
\par \hich\af0\dbch\af31505\loch\f0    \{
\par \hich\af0\dbch\af31505\loch\f0       if(a[i]==se)
\par \hich\af0\dbch\af31505\loch\f0       \{
\par \hich\af0\dbch\af31505\loch\f0              ck=1;
\par \hich\af0\dbch\af31505\loch\f0              printf("\\n%d is found at a[%d]",se,i);
\par \hich\af0\dbch\af31505\loch\f0       \}
\par \hich\af0\dbch\af31505\loch\f0    \}
\par \hich\af0\dbch\af31505\loch\f0    if(ck==0)
\par \hich\af0\dbch\af31505\loch\f0      printf("%d is not found",se);
\par \hich\af0\dbch\af31505\loch\f0    getch();
\par \}
\par 
