\par \{
\par \hich\af0\dbch\af31505\loch\f0   int a[10][10],r,c,i,j;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter number of rows and columns : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d%d",&r,&c);
