\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Example }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 :   }{
\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 st_det.c
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 To enter student number, name, marks in C,CPP,java and to calculate and display total marks, average, result and division
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int sno,c,cpp,java,tot;
\par \hich\af0\dbch\af31505\loch\f0   char sname[20],res[5],div[10];
\par \hich\af0\dbch\af31505\loch\f0   float avg;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter student number      : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&sno);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter student name        : ");
\par \hich\af0\dbch\af31505\loch\f0   fflush(stdin);
\par \hich\af0\dbch\af31505\loch\f0   gets(sname);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter marks in C       \hich\af0\dbch\af31505\loch\f0    : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&c);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter marks in CPP        : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&cpp);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter marks in Java       : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&java);
\par \hich\af0\dbch\af31505\loch\f0   tot=c+cpp+java;
\par \hich\af0\dbch\af31505\loch\f0   avg=(float)tot/3;
\par \hich\af0\dbch\af31505\loch\f0     clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Student Number    :  %d",sno);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\\hich\af0\dbch\af31505\loch\f0 nStudent  Name     :  %s",sname);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nMarks in C        :  %d",c);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nMarks in CPP      :  %d",cpp);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nMarks in Java     :  %d",java);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nTotal Marks       :  %d",tot);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nAverage Marks     :  %.2f",avg);
\par 
\par \hich\af0\dbch\af31505\loch\f0   if(\hich\af0\dbch\af31505\loch\f0 c>=50 && cpp>=50 && java>=50)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     printf("\\nResult            :  PASS ");
\par \hich\af0\dbch\af31505\loch\f0     if(avg>=60)
\par \hich\af0\dbch\af31505\loch\f0       printf("\\nDivision          :  FIRST");
\par \hich\af0\dbch\af31505\loch\f0     else
\par \hich\af0\dbch\af31505\loch\f0       printf("\\nDivision        :  SECOND");
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   else
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     printf("\\nResult            :  FAIL");
\par \hich\af0\dbch\af31505\loch\f0     \hich\af0\dbch\af31505\loch\f0 printf("\\nDivision          :  NO DIVISION");
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par 
\par 
\par 
\par 
