\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h\hich\af0\dbch\af31505\loch\f0 >
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int eno;
\par \hich\af0\dbch\af31505\loch\f0   char ename[20],gr;
\par \hich\af0\dbch\af31505\loch\f0   float basic,hra,da,ta,it,pf,gs,ded,ns;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter Employee Number    : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&eno);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter Employee Name      : ");
\par \hich\af0\dbch\af31505\loch\f0   fflush(stdin);
\par \hich\af0\dbch\af31505\loch\f0   gets(ename);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter Employee Grade     : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%c",&gr);
\par \hich\af0\dbch\af31505\loch\f0   if(gr=='A' && gr=='B' && gr=='a' && gr=='b')
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     printf("Invalid Grade");
\par \hich\af0\dbch\af31505\loch\f0     getch();
\par \hich\af0\dbch\af31505\loch\f0     exit(0);
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter Basic Salary       : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%f",&basic);
\par \hich\af0\dbch\af31505\loch\f0   if(gr=='a' || gr=='A'\hich\af0\dbch\af31505\loch\f0 )
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     if(basic<=2000)
\par \hich\af0\dbch\af31505\loch\f0     \{
\par \hich\af0\dbch\af31505\loch\f0       hra=basic*10/100;
\par \hich\af0\dbch\af31505\loch\f0       da=basic*15/100;
\par \hich\af0\dbch\af31505\loch\f0       ta=basic*3/100;
\par \hich\af0\dbch\af31505\loch\f0       it=0;
\par \hich\af0\dbch\af31505\loch\f0       pf=basic*5/100;
\par \hich\af0\dbch\af31505\loch\f0     \}
\par \hich\af0\dbch\af31505\loch\f0     else if(basic<=5000)
\par \hich\af0\dbch\af31505\loch\f0     \{
\par \hich\af0\dbch\af31505\loch\f0       hra=basic*15/100;
\par \hich\af0\dbch\af31505\loch\f0       da=basic*20/100;
\par \hich\af0\dbch\af31505\loch\f0       ta=basic*5/100;
\par \hich\af0\dbch\af31505\loch\f0       it=basic*3/100;
\par \hich\af0\dbch\af31505\loch\f0       pf=basic*8/100;
\par \hich\af0\dbch\af31505\loch\f0     \}
\par \hich\af0\dbch\af31505\loch\f0     else
\par \hich\af0\dbch\af31505\loch\f0     \{
\par \hich\af0\dbch\af31505\loch\f0       hra=basic*20/100;
\par \hich\af0\dbch\af31505\loch\f0       da=basic*25/100;
\par \hich\af0\dbch\af31505\loch\f0       ta=basic*8/100;
\par \hich\af0\dbch\af31505\loch\f0       it=basic*5/100;
\par \hich\af0\dbch\af31505\loch\f0       pf=basic*12/100;
\par \hich\af0\dbch\af31505\loch\f0      \}
\par \hich\af0\dbch\af31505\loch\f0    \}
\par \hich\af0\dbch\af31505\loch\f0    else
\par \hich\af0\dbch\af31505\loch\f0    \{
\par \hich\af0\dbch\af31505\loch\f0       if(basic<=3000)
\par \hich\af0\dbch\af31505\loch\f0       \{
\par \hich\af0\dbch\af31505\loch\f0              hra=basic\hich\af0\dbch\af31505\loch\f0 *8/100;
\par \hich\af0\dbch\af31505\loch\f0              da=basic*10/100;
\par \hich\af0\dbch\af31505\loch\f0               ta=basic*2/100;
\par \hich\af0\dbch\af31505\loch\f0               it=0;
\par \hich\af0\dbch\af31505\loch\f0               pf=basic*4/100;
\par \hich\af0\dbch\af31505\loch\f0       \}
\par \hich\af0\dbch\af31505\loch\f0       else if(basic<=5000)
\par \hich\af0\dbch\af31505\loch\f0       \{
\par \hich\af0\dbch\af31505\loch\f0                hra=basic*10/100;
\par \hich\af0\dbch\af31505\loch\f0               da=basic*12/100;
\par \hich\af0\dbch\af31505\loch\f0                ta=basic*4/100;
\par \hich\af0\dbch\af31505\loch\f0                it=basic*2/100;
\par \hich\af0\dbch\af31505\loch\f0                pf=basic*8/100;
\par \hich\af0\dbch\af31505\loch\f0       \}
\par \hich\af0\dbch\af31505\loch\f0       else
\par \hich\af0\dbch\af31505\loch\f0       \{
\par \hich\af0\dbch\af31505\loch\f0             hra=basic*15/100;
\par \hich\af0\dbch\af31505\loch\f0             da=basic*18/100;
\par \hich\af0\dbch\af31505\loch\f0             ta=basic*5/100;
\par \hich\af0\dbch\af31505\loch\f0             it=basic*4/100;
\par \hich\af0\dbch\af31505\loch\f0             pf=basic*10/100;
\par \hich\af0\dbch\af31505\loch\f0       \}
\par \hich\af0\dbch\af31505\loch\f0    \}
\par \hich\af0\dbch\af31505\loch\f0    gs=basi\hich\af0\dbch\af31505\loch\f0 c+hra+da+ta;
\par \hich\af0\dbch\af31505\loch\f0    ded=it+pf;
\par \hich\af0\dbch\af31505\loch\f0    ns=gs-ded;
\par \hich\af0\dbch\af31505\loch\f0    clrscr();
\par \hich\af0\dbch\af31505\loch\f0    printf("\\t\\t\\t EMPLOYEE DETAILS \\n\\n");
\par \hich\af0\dbch\af31505\loch\f0    printf("\\nEmployee Number       : %d",eno);
\par \hich\af0\dbch\af31505\loch\f0    printf("\\nEmployee Name         : %s",ename);
\par \hich\af0\dbch\af31505\loch\f0    printf("\\nEmployee Grade        : %c",gr);
\par \hich\af0\dbch\af31505\loch\f0    printf("\\nBasi\hich\af0\dbch\af31505\loch\f0 c Salary          : %.2f",basic);
\par \hich\af0\dbch\af31505\loch\f0    printf("\\nHouse Rent Allowance : %.2f",hra);
\par \hich\af0\dbch\af31505\loch\f0    printf("\\nDearness Allowance    : %.2f",da);
\par \hich\af0\dbch\af31505\loch\f0    printf("\\nTravelling Allowance  : %.2f",ta);
\par \hich\af0\dbch\af31505\loch\f0    printf("\\nIncome tax            : %.2f",it);
\par \hich\af0\dbch\af31505\loch\f0    printf("\\\hich\af0\dbch\af31505\loch\f0 nProvident Fund        : %.2f",pf);
\par \hich\af0\dbch\af31505\loch\f0    printf("\\nGross Salary          : %.2f",gs);
\par \hich\af0\dbch\af31505\loch\f0    printf("\\nDeductions            : %.2f",ded);
\par \hich\af0\dbch\af31505\loch\f0    printf("\\nNet Salary            : %.2f",ns);
\par \hich\af0\dbch\af31505\loch\f0    getch();
\par \}
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Program :}{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0   }{
\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 dealer.c
\par 
\par \hich\af0\dbch\af31505\loch\f0  To enter dealer number, name, number of\hich\af0\dbch\af31505\loch\f0 
 litres petrol sold, no of lit diesel sold, no of lit kerosene sold and dealer regions are north-N,west-W,east-E,south-S.Calculate and display total amount by the following table.
\par 
\par 
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0            Region                     Petrol                  Diesel     \hich\af0\dbch\af31505\loch\f0              Kerosene
\par \hich\af0\dbch\af31505\loch\f0                                          (rate/litre)             (rate/lit)                 (rate/lit)
\par 
\par \hich\af0\dbch\af31505\loch\f0                N                          50.75                   31.85                    22.15
\par 
\par \hich\af0\dbch\af31505\loch\f0                S               \hich\af0\dbch\af31505\loch\f0             49.85                   30.25                   21.50
\par 
\par \hich\af0\dbch\af31505\loch\f0               W                          52.35                   33.75                   24.65
\par 
\par \hich\af0\dbch\af31505\loch\f0                E                          51.45                   32.15                   23.\hich\af0\dbch\af31505\loch\f0 75  
\par 
\par 
\par 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int dno,np,nd,nk;
\par \hich\af0\dbch\af31505\loch\f0   char dname[20],reg;
\par \hich\af0\dbch\af31505\loch\f0   float pa,da,ka,ta;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter dealer number       : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&dno);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter dealer name        : ");
\par \hich\af0\dbch\af31505\loch\f0   fflush(stdin);
\par \hich\af0\dbch\af31505\loch\f0   gets(dname);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter dealer region      : ");
\par \hich\af0\dbch\af31505\loch\f0   fflush(stdin);
\par \hich\af0\dbch\af31505\loch\f0   scanf("%c",&reg);
\par \hich\af0\dbch\af31505\loch\f0   if(reg>=97 && reg<=122)
\par \hich\af0\dbch\af31505\loch\f0     reg=reg-32;  // this is to convert lower case letters to upper case letters //
\par \hich\af0\dbch\af31505\loch\f0   if(reg!='N' && reg!='W' && reg!='S' && reg!='E')
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     printf("Invalid Region");
\par \hich\af0\dbch\af31505\loch\f0     getch();
\par \hich\af0\dbch\af31505\loch\f0     exit(0);
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter number of litres of petrol sold    : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&np);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter number of litres of diesel sold    : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&nd);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter number of litres of kerosene sold  : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&nk);
\par \hich\af0\dbch\af31505\loch\f0   if(reg=='N')
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     pa=np*50.75;
\par \hich\af0\dbch\af31505\loch\f0     da=nd*31.85;
\par \hich\af0\dbch\af31505\loch\f0     ka=nk*22.15;
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   else if(reg=='S')
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     pa=np*49.85;
\par \hich\af0\dbch\af31505\loch\f0     da=nd*30.25;
\par \hich\af0\dbch\af31505\loch\f0     ka=nk*21.50;
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   else if(reg=='W')
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0    \hich\af0\dbch\af31505\loch\f0  pa=np*52.35;
\par \hich\af0\dbch\af31505\loch\f0     da=nd*33.75;
\par \hich\af0\dbch\af31505\loch\f0     ka=nk*24.65;
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   else
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     pa=np*51.45;
\par \hich\af0\dbch\af31505\loch\f0     da=nd*32.15;
\par \hich\af0\dbch\af31505\loch\f0     ka=nk*23.75;
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   ta=pa+da+ka;
\par \hich\af0\dbch\af31505\loch\f0   printf("Dealer Number            : %d",dno);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nDealer Name              : %s",dname);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\\hich\af0\dbch\af31505\loch\f0 nDealer Region            : %c",reg);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nLitres of petrol sold    : %d",np);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nLitres of deesel sold    : %d",nd);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nLitres of keroene sold   : %d",nk);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nPetrol Amount            :%.2f",pa);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nDeesel Amount\hich\af0\dbch\af31505\loch\f0             :%.2f",da);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nKerosene Amount          :%.2f",ka);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nTota l Amount            :%.2f",ta);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
