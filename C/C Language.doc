\par \hich\af0\dbch\af31505\loch\f0     scanf("%f",&s.fee);
\par \hich\af0\dbch\af31505\loch\f0     fwrite(&s,sizeof(s),1,fp);
\par \hich\af0\dbch\af31505\loch\f0     printf("\\nRecord saved successfully");
