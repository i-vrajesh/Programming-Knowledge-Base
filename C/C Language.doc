\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int maxval(int,int);
\par \hich\af0\dbch\af31505\loch\f0   int a,b,c,m;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter 3 numbrs : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d%d%d",&a,&b,&c);
\par \hich\af0\dbch\af31505\loch\f0   m=maxval(a,b);
\par \hich\af0\dbch\af31505\loch\f0   m=maxval(m,c);
\par \hich\af0\dbch\af31505\loch\f0   printf("Maximum Value : %d",m);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par \hich\af0\dbch\af31505\loch\f0 int maxval(int x,int y)
\par \{
\par \hich\af0\dbch\af31505\loch\f0   if(x>y)
\par \hich\af0\dbch\af31505\loch\f0     return x;
\par \hich\af0\dbch\af31505\loch\f0   else
\par \hich\af0\dbch\af31505\loch\f0     return y;
