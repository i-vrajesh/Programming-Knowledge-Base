\par \hich\af0\dbch\af31505\loch\f0     fflush(stdin);
\par \hich\af0\dbch\af31505\loch\f0     gets(\hich\af0\dbch\af31505\loch\f0 s.sname);
\par \hich\af0\dbch\af31505\loch\f0     printf("Enter course : ");
\par \hich\af0\dbch\af31505\loch\f0     fflush(stdin);
\par \hich\af0\dbch\af31505\loch\f0     gets(s.course);
