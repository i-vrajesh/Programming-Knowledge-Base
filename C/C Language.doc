\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{\hich\af0\dbch\af31505\loch\f0    \hich\af0\dbch\af31505\loch\f0                                                        
\par \hich\af0\dbch\af31505\loch\f0   void setdata(int *);
\par \hich\af0\dbch\af31505\loch\f0   int a;
