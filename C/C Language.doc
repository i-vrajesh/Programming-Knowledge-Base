\par }{\rtlch\fcs1 \ab\ai\af44\afs44 \ltrch\fcs0 \b\i\f44\fs28\insrsid11017018\charrsid13244520 \hich\af44\dbch\af31505\loch\f44 Scrolling the given string on screen center
\par }{\rtlch\fcs1 \af44\afs44 \ltrch\fcs0 \f44\fs28\insrsid11017018\charrsid13244520 
\par \hich\af44\dbch\af31505\loch\f44 #include<stdio.h>
\par \hich\af44\dbch\af31505\loch\f44 #include<conio.h>
\par \hich\af44\dbch\af31505\loch\f44 void main()
\par \{
\par \hich\af44\dbch\af31505\loch\f44   char st[40],ch;
\par \hich\af44\dbch\af31505\loch\f44   int c,i;
\par \hich\af44\dbch\af31505\loch\f44   clrscr();
\par \hich\af44\dbch\af31505\loch\f44   printf("Enter a string : ");
\par \hich\af44\dbch\af31505\loch\f44   gets(st);
\par \hich\af44\dbch\af31505\loch\f44   strcat(st,"     ");
\par \hich\af44\dbch\af31505\loch\f44   strupr(st);
\par \hich\af44\dbch\af31505\loch\f44   clrscr();
\par \hich\af44\dbch\af31505\loch\f44   textmode(1);
\par \hich\af44\dbch\af31505\loch\f44   _setcursortype(_NOCURSOR);
\par \hich\af44\dbch\af31505\loch\f44   textbackground(WHITE);
\par \hich\af44\dbch\af31505\loch\f44   textcolor(RED);
\par \hich\af44\dbch\af31505\loch\f44   c=(40-strlen(st))/2;
\par \hich\af44\dbch\af31505\loch\f44   gotoxy(c,12);
\par \hich\af44\dbch\af31505\loch\f44   cprintf("%s",st);
\par \hich\af44\dbch\af31505\loch\f44   while(!kbhit())
\par \hich\af44\dbch\af31505\loch\f44   \{
\par \hich\af44\dbch\af31505\loch\f44     ch=st[0];
\par \hich\af44\dbch\af31505\loch\f44     for(i=0;i<strlen(st);i++)
\par \hich\af44\dbch\af31505\loch\f44     \{
\par \hich\af44\dbch\af31505\loch\f44       st[i]=\hich\af44\dbch\af31505\loch\f44 st[i+1];
\par \hich\af44\dbch\af31505\loch\f44     \}
\par \hich\af44\dbch\af31505\loch\f44     st[i-1]=ch;
\par \hich\af44\dbch\af31505\loch\f44     st[i]='\\0';
\par \hich\af44\dbch\af31505\loch\f44     gotoxy(c,12);
\par \hich\af44\dbch\af31505\loch\f44     cprintf("%s",st);
\par \hich\af44\dbch\af31505\loch\f44     delay(100);
\par \hich\af44\dbch\af31505\loch\f44   \}
\par \hich\af44\dbch\af31505\loch\f44   getch();
\par \}
\par 
\par \hich\af44\dbch\af31505\loch\f44  
\par 
\par }{\rtlch\fcs1 \ab\af44\afs32 \ltrch\fcs0 \b\f44\fs20\ul\insrsid11017018\charrsid13244520 \hich\af44\dbch\af31505\loch\f44 Two dimensional character arrays (String array) :
\par }{\rtlch\fcs1 \af44\afs44 \ltrch\fcs0 \f44\fs28\insrsid11017018\charrsid13244520 \hich\af44\dbch\af31505\loch\f44     A list of strings can be treated as a ta\hich\af44\dbch\af31505\loch\f44 
ble of strings and a two dimensional character array can be used to store the entire list.
\par }{\rtlch\fcs1 \ab\ai\af44\afs44 \ltrch\fcs0 \b\i\f44\fs28\insrsid11017018\charrsid13244520 \hich\af44\dbch\af31505\loch\f44 For example :
\par }{\rtlch\fcs1 \af44\afs44 \ltrch\fcs0 \f44\fs28\insrsid11017018\charrsid13244520 \hich\af44\dbch\af31505\loch\f44     char st[20][20] may be used to store a list of 20 strings, each of length not more than 20 characters.
\par 
\par 
\par 
\par 
\par }{\rtlch\fcs1 \ab\af44\afs44 \ltrch\fcs0 \b\f44\fs28\ul\insrsid11017018\charrsid13244520 \hich\af44\dbch\af31505\loch\f44 Program :}{\rtlch\fcs1 \ab\af44\afs44 \ltrch\fcs0 \b\f44\fs28\insrsid11017018\charrsid13244520 \hich\af44\dbch\af31505\loch\f44 
  strarr1.c
\par }{\rtlch\fcs1 \af44\afs44 \ltrch\fcs0 \f44\fs28\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\ai\af44\afs44 \ltrch\fcs0 \b\i\f44\fs28\insrsid11017018\charrsid13244520 \hich\af44\dbch\af31505\loch\f44 To enter group of \hich\af44\dbch\af31505\loch\f44 strings and to display them
\par }{\rtlch\fcs1 \af44\afs44 \ltrch\fcs0 \f44\fs28\insrsid11017018\charrsid13244520 
\par \hich\af44\dbch\af31505\loch\f44 #include<stdio.h>
\par \hich\af44\dbch\af31505\loch\f44 #include<conio.h>
\par \hich\af44\dbch\af31505\loch\f44 void main()
\par \{
\par \hich\af44\dbch\af31505\loch\f44    char st[20][20];
\par \hich\af44\dbch\af31505\loch\f44    int n,i;
\par \hich\af44\dbch\af31505\loch\f44    clrscr();
\par \hich\af44\dbch\af31505\loch\f44    printf("Enter number of strings : ");
\par \hich\af44\dbch\af31505\loch\f44    scanf("%d",&n);
\par \hich\af44\dbch\af31505\loch\f44    printf("Enter %d strings : ",n);
\par \hich\af44\dbch\af31505\loch\f44    fflush(stdin);
\par \hich\af44\dbch\af31505\loch\f44    for(i=0;i<n;i++)
\par \hich\af44\dbch\af31505\loch\f44    \{
\par \hich\af44\dbch\af31505\loch\f44      gets(st[i]);
\par \hich\af44\dbch\af31505\loch\f44    \}
\par \hich\af44\dbch\af31505\loch\f44    printf("\\nGiven strings : ");
\par \hich\af44\dbch\af31505\loch\f44    for(i=0;i<n;i++)
\par \hich\af44\dbch\af31505\loch\f44    \{
\par \hich\af44\dbch\af31505\loch\f44      puts(st[i]);
\par \hich\af44\dbch\af31505\loch\f44    \}
\par \hich\af44\dbch\af31505\loch\f44    getch();
\par \}
\par 
\par }{\rtlch\fcs1 \ab\af44\afs44 \ltrch\fcs0 \b\f44\fs28\ul\insrsid11017018\charrsid13244520 \hich\af44\dbch\af31505\loch\f44 Program :}{\rtlch\fcs1 \ab\af44\afs44 \ltrch\fcs0 \b\f44\fs28\insrsid11017018\charrsid13244520 \hich\af44\dbch\af31505\loch\f44 
  strarr2.c
\par }{\rtlch\fcs1 \af44\afs44 \ltrch\fcs0 \f44\fs28\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\ai\af44\afs44 \ltrch\fcs0 \b\i\f44\fs28\insrsid11017018\charrsid13244520 \hich\af44\dbch\af31505\loch\f44 To enter group of strings and to display them in alphabetical order
\par }{\rtlch\fcs1 \af44\afs44 \ltrch\fcs0 \f44\fs28\insrsid11017018\charrsid13244520 
\par \hich\af44\dbch\af31505\loch\f44 #include<stdio.h>
\par \hich\af44\dbch\af31505\loch\f44 #in\hich\af44\dbch\af31505\loch\f44 clude<conio.h>
\par \hich\af44\dbch\af31505\loch\f44 void main()
\par \{
\par \hich\af44\dbch\af31505\loch\f44    char st[20][20],t[20];
\par \hich\af44\dbch\af31505\loch\f44    int n,i,j,k;
\par \hich\af44\dbch\af31505\loch\f44    clrscr();
\par \hich\af44\dbch\af31505\loch\f44    printf("Enter number of strings : ");
\par \hich\af44\dbch\af31505\loch\f44    scanf("%d",&n);
\par \hich\af44\dbch\af31505\loch\f44    printf("Enter %d strings : \\n",n);
\par \hich\af44\dbch\af31505\loch\f44    fflush(stdin);
\par \hich\af44\dbch\af31505\loch\f44    for(i=0;i<n;i++)
\par \hich\af44\dbch\af31505\loch\f44    \{
\par \hich\af44\dbch\af31505\loch\f44      gets(st[i]);
\par \hich\af44\dbch\af31505\loch\f44    \}
\par \hich\af44\dbch\af31505\loch\f44    printf("\\nGiven strings : \\n");
\par \hich\af44\dbch\af31505\loch\f44    for(i=0;i<n;i++)
\par \hich\af44\dbch\af31505\loch\f44    \{
\par \hich\af44\dbch\af31505\loch\f44      puts(st[i]);
\par \hich\af44\dbch\af31505\loch\f44    \}
\par \hich\af44\dbch\af31505\loch\f44    // soring //
\par \hich\af44\dbch\af31505\loch\f44    for(i=0;i<n-1;i++)
\par \hich\af44\dbch\af31505\loch\f44    \{
\par \hich\af44\dbch\af31505\loch\f44      for(j=i+1;j<n;j++)
\par \hich\af44\dbch\af31505\loch\f44      \{
\par \hich\af44\dbch\af31505\loch\f44        k=strcmp(st[i],st[j]);
\par \hich\af44\dbch\af31505\loch\f44        if(k>0)
\par \hich\af44\dbch\af31505\loch\f44        \{
\par \hich\af44\dbch\af31505\loch\f44              strcpy(t,st[i]);
\par \hich\af44\dbch\af31505\loch\f44              st\hich\af44\dbch\af31505\loch\f44 rcpy(st[i],st[j]);
\par \hich\af44\dbch\af31505\loch\f44              strcpy(st[j],t);
\par \hich\af44\dbch\af31505\loch\f44        \}
\par \hich\af44\dbch\af31505\loch\f44      \}
\par \hich\af44\dbch\af31505\loch\f44    \}
\par \hich\af44\dbch\af31505\loch\f44    printf("\\nGiven strings in Alphabetical order : \\n");
\par \hich\af44\dbch\af31505\loch\f44    for(i=0;i<n;i++)
\par \hich\af44\dbch\af31505\loch\f44    \{
\par \hich\af44\dbch\af31505\loch\f44      puts(st[i]);
\par \hich\af44\dbch\af31505\loch\f44    \}
\par \hich\af44\dbch\af31505\loch\f44    getch();
\par \}
\par \hich\af44\dbch\af31505\loch\f44  
\par 
