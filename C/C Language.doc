\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 To find the maximum and minimum values of given 2 VALUES
\par 
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int a,b,max,min;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter 2 numbers : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d%d",&a,&b);
\par \hich\af0\dbch\af31505\loch\f0   max=a>b ? a : b;
\par \hich\af0\dbch\af31505\loch\f0   min=a<b ? a : b;
\par \hich\af0\dbch\af31505\loch\f0   printf("Maximim value   : %d",max);
\par \hich\af0\dbch\af31505\loch\f0   pri`ntf("\\nMinimum value   : %d",min);
\par \hich\af0\dbch\af31505\loch\f0   getch();
