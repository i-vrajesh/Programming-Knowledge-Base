\par 
\par \hich\af44\dbch\af31505\loch\f44       Quotient    Remaind\hich\af44\dbch\af31505\loch\f44 er
\par \hich\af44\dbch\af31505\loch\f44 25/2  = 12        1      LSB (least significant bit)
\par \hich\af44\dbch\af31505\loch\f44 12/2  =   6        0 
\par \hich\af44\dbch\af31505\loch\f44   6/2  =   3        0   
\par \hich\af44\dbch\af31505\loch\f44   3/2  =   1        1
\par \hich\af44\dbch\af31505\loch\f44   1/2  =   0        1      MSB (most significant bit)
