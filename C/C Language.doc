\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   void accept(int[],int);
\par \hich\af0\dbch\af31505\loch\f0   void disp(int[],int);
\par \hich\af0\dbch\af31505\loch\f0   int search(int[],int,int);
\par \hich\af0\dbch\af31505\loch\f0   int a[20],n,se,p;
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter number of elements : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter elements : ");
\par \hich\af0\dbch\af31505\loch\f0   accept(a,n);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nGiven Elements :");
\par \hich\af0\dbch\af31505\loch\f0   disp(a,n);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nEnter element to search : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&se);
\par \hich\af0\dbch\af31505\loch\f0   p=search(a,n,se);
\par \hich\af0\dbch\af31505\loch\f0   if(p==-1)
\par \hich\af0\dbch\af31505\loch\f0     printf("%\hich\af0\dbch\af31505\loch\f0 d is not found",se);
\par \hich\af0\dbch\af31505\loch\f0   else
\par \hich\af0\dbch\af31505\loch\f0     printf("%d is found at position %d",se,p);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par \hich\af0\dbch\af31505\loch\f0 void accept(int a[],int n)
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int i;
\par \hich\af0\dbch\af31505\loch\f0   for(i=0;i<n;i++)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     scanf("%d",&a[i]);
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \}
\par \hich\af0\dbch\af31505\loch\f0 void disp(int a[],int n)
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int i;
