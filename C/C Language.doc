\par }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0  To test all arithmetic operations using switch statement 
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0    int a,b,opt;
\par \hich\af0\dbch\af31505\loch\f0    clrscr();
\par \hich\af0\dbch\af31505\loch\f0    printf("Enter two numbers : ");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d%d",&a,&b);
\par \hich\af0\dbch\af31505\loch\f0    printf("1-Addition\\n2-Subtraction\\n3-Multiplication\\n4-\hich\af0\dbch\af31505\loch\f0 Division
\par \hich\af0\dbch\af31505\loch\f0                                                   \\n5-Modulus\\nEnter your option : ");
\par \hich\af0\dbch\af31505\loch\f0    scanf("%d",&opt);
\par \hich\af0\dbch\af31505\loch\f0    switch(opt)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0       case 1:
\par \hich\af0\dbch\af31505\loch\f0             printf("Addition of %d and %d is %d",a,b,a+b);
\par \hich\af0\dbch\af31505\loch\f0             break;
\par 
\par \hich\af0\dbch\af31505\loch\f0       case 2:
\par \hich\af0\dbch\af31505\loch\f0              \hich\af0\dbch\af31505\loch\f0 printf("Subtraction of %d and %d is %d",a,b,a-b);
\par \hich\af0\dbch\af31505\loch\f0              break;
\par 
\par \hich\af0\dbch\af31505\loch\f0       case 3:
\par \hich\af0\dbch\af31505\loch\f0             printf("Multiplication of %d and %d is %d",a,b,a*b);
\par \hich\af0\dbch\af31505\loch\f0             break;
\par 
\par \hich\af0\dbch\af31505\loch\f0       case 4:
\par \hich\af0\dbch\af31505\loch\f0            printf("Division of %d and %d is %.2f",a,b,(float)a/b);
\par \hich\af0\dbch\af31505\loch\f0      \hich\af0\dbch\af31505\loch\f0       break;
\par \hich\af0\dbch\af31505\loch\f0       case 5:
\par \hich\af0\dbch\af31505\loch\f0            printf("Modulus of %d and %d is %d",a,b,a%b);
\par \hich\af0\dbch\af31505\loch\f0            break;
\par 
\par \hich\af0\dbch\af31505\loch\f0       default:
\par \hich\af0\dbch\af31505\loch\f0            printf("Invalid Option");
\par \hich\af0\dbch\af31505\loch\f0    \}
\par \hich\af0\dbch\af31505\loch\f0    getch();
\par \}
\par 
\par 
\par 
