\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int i,n,a[20],max,min;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter number of Elements : ");\\
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&n);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nEnter Elements  : ");
\par \hich\af0\dbch\af31505\loch\f0   for(i=0;i<n;i++)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     scanf("%d",&a[i]);
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   max=min=a[0];
\par \hich\af0\dbch\af31505\loch\f0   for(i=1;i<n;i++)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     if(a[i]>max)
\par \hich\af0\dbch\af31505\loch\f0       max=a[i];
\par \hich\af0\dbch\af31505\loch\f0     if(a[i]<min)
\par \hich\af0\dbch\af31505\loch\f0       min=a[i];
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nMaximum Element : %d",max);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nMinimum Element : %d",min);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par 
