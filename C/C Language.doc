\par \hich\af0\dbch\af31505\loch\f0 To enter\hich\af0\dbch\af31505\loch\f0  consumer number, name, present month reading, last month reading. calculate and display total units and bill amount by the following table.
\par }{\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\insrsid11017018\charrsid13244520 
\par \hich\af0\dbch\af31505\loch\f0                                       Units                    rate/unit
\par 
\par }\pard \ltrpar\qj \li0\ri0\sl360\slmult1\nowidctlpar\tqr\tx8640\wrapdefault\faauto\rin0\lin0\itap0 {\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0                                       0
\hich\af0\dbch\af31505\loch\f0  \hich\f0 \endash \loch\f0  50                  1.45(min)
\par \hich\af0\dbch\af31505\loch\f0                                      51-100                     2.80
\par \hich\af0\dbch\af31505\loch\f0                                     101-200                    3.05
\par \hich\af0\dbch\af31505\loch\f0                                     201-300                    4.75
\par \hich\af0\dbch\af31505\loch\f0                                       >300                       5.50            
\par }\pard \ltrpar\qj \li0\ri0\nowidctlpar\tqr\tx8640\wrapdefault\faauto\rin0\lin0\itap0 {\rtlch\fcs1 \af0\afs40 \ltrch\fcs0 \f0\fs24\insrsid11017018\charrsid13244520 
\par 
\par \hich\af0\dbch\af31505\loch\f0 #include<stdio.h>
\par \hich\af0\dbch\af31505\loch\f0 #include<conio.h>
\par \hich\af0\dbch\af31505\loch\f0 void main()
\par \{
\par \hich\af0\dbch\af31505\loch\f0   int cno,pmr,lmr,tu;
\par \hich\af0\dbch\af31505\loch\f0   char cname[20];
\par \hich\af0\dbch\af31505\loch\f0   float bamt;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter consumer number : ");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&cno)\hich\af0\dbch\af31505\loch\f0 ;
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter consumer name   :");
\par \hich\af0\dbch\af31505\loch\f0   fflush(stdin);
\par \hich\af0\dbch\af31505\loch\f0   gets(cname);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter present month reading :");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&pmr);
\par \hich\af0\dbch\af31505\loch\f0   printf("Enter last month reading    :");
\par \hich\af0\dbch\af31505\loch\f0   scanf("%d",&lmr);
\par \hich\af0\dbch\af31505\loch\f0   if(pmr<lmr)
\par \hich\af0\dbch\af31505\loch\f0   \{
\par \hich\af0\dbch\af31505\loch\f0     printf("Invalid reading");
\par \hich\af0\dbch\af31505\loch\f0     getch(\hich\af0\dbch\af31505\loch\f0 );
\par \hich\af0\dbch\af31505\loch\f0     exit(0);
\par \hich\af0\dbch\af31505\loch\f0   \}
\par \hich\af0\dbch\af31505\loch\f0   tu=pmr-lmr;
\par \hich\af0\dbch\af31505\loch\f0   if(tu<=50)
\par \hich\af0\dbch\af31505\loch\f0     bamt=50*1.45;
\par \hich\af0\dbch\af31505\loch\f0   else if(tu<=100)
\par \hich\af0\dbch\af31505\loch\f0     bamt=50*1.45+(tu-50)*2.80;
\par \hich\af0\dbch\af31505\loch\f0   else if(tu<=200)
\par \hich\af0\dbch\af31505\loch\f0     bamt=(50*1.45)+(50*2.80)+(tu-100)*3.05;
\par \hich\af0\dbch\af31505\loch\f0   else if(tu<=300)
\par \hich\af0\dbch\af31505\loch\f0     bamt=(50*1.45)+(50*2.80)+(100*3.05)+(tu-200)*4.75;
\par \hich\af0\dbch\af31505\loch\f0   else
\par \hich\af0\dbch\af31505\loch\f0     bamt=(50*1.45)+(50*2.80)+(100*3.05)+(100*4.75)+(tu-300)*5.50;
\par \hich\af0\dbch\af31505\loch\f0   clrscr();
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nConsumer Number        : %d",cno);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nConsumer Name          : %s",cname);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nPresent month reading  : %d",pmr);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nLast month readi\hich\af0\dbch\af31505\loch\f0 ng     : %d",lmr);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nTotal units            : %d",tu);
\par \hich\af0\dbch\af31505\loch\f0   printf("\\nTotal Bill Amount      : %.2f",bamt);
\par \hich\af0\dbch\af31505\loch\f0   getch();
\par \}
\par 
\par 
\par }{\rtlch\fcs1 \ab\af0\afs40 \ltrch\fcs0 \b\f0\fs24\ul\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 Example }{\rtlch\fcs1 \ab\ai\af0\afs40 \ltrch\fcs0 \b\i\f0\fs24\insrsid11017018\charrsid13244520 \hich\af0\dbch\af31505\loch\f0 
: emp_sal.c
